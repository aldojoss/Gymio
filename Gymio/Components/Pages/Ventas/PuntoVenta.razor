@page "/punto-venta"
@attribute [Authorize(Roles = "Administrador,Empleado")]
@rendermode InteractiveServer

@using Gymio.Models
@using Gymio.Interfaces
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

@inject IVentaService VentaService
@inject IClienteService ClienteService
@inject ITurnoCajaService CajaService // NUEVO: Inyectamos el servicio de la Caja
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation // NUEVO: Para redirigir si no hay caja abierta
@inject IJSRuntime JS

<PageTitle>Punto de Venta - Gymio</PageTitle>

<div class="pos-container d-flex gap-4 overflow-hidden fade-in text-light">
    
    @* LADO IZQUIERDO: CATÁLOGO DE PRODUCTOS *@
    <div class="products-section flex-grow-1 p-4 d-flex flex-column">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-black text-white mb-0"><i class="bi bi-shop me-2 text-primary"></i>Punto de Venta</h2>
                <span class="text-muted small tracking-widest text-uppercase">Ventas rápidas de mostrador</span>
                
                @* NUEVO: Etiqueta avisando a qué turno se está sumando la plata *@
                @if (turnoActivo != null)
                {
                    <span class="badge bg-success bg-opacity-25 text-success border border-success ms-3 shadow-sm" style="font-size: 0.75rem;">
                        <i class="bi bi-unlock-fill me-1"></i> Caja Abierta (#@turnoActivo.Id)
                    </span>
                }
            </div>
            
            <div class="input-group bg-dark border border-secondary border-opacity-25 rounded-pill overflow-hidden shadow-sm" style="max-width: 350px;">
                <span class="input-group-text bg-transparent border-0 text-muted ps-4"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control bg-transparent border-0 text-white shadow-none py-2" placeholder="Buscar producto..." @bind="filtroBusqueda" @bind:event="oninput" />
            </div>
        </div>

        <div class="row g-3 overflow-auto custom-scrollbar flex-grow-1 pb-4 pe-2 align-content-start">
            @if (productosCargando)
            {
                <div class="col-12 text-center py-5"><div class="spinner-border text-primary"></div></div>
            }
            else if (!productosFiltrados.Any())
            {
                <div class="col-12 text-center py-5 fade-in">
                    <div class="bg-dark rounded-circle p-4 d-inline-block mb-3 border border-secondary border-opacity-25 shadow">
                        <i class="bi bi-box-seam display-5 text-white-50"></i>
                    </div>
                    <h5 class="fw-bold text-white mb-2">Sin productos disponibles</h5>
                    <p class="text-muted small">No hay productos activos o que coincidan con la búsqueda.</p>
                </div>
            }
            else
            {
                @foreach (var prod in productosFiltrados)
                {
                    <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                        <div class="card product-card bg-dark border-secondary border-opacity-25 rounded-4 shadow-sm @(prod.StockActual <= 0 ? "opacity-50" : "")">
                            <div class="card-body p-3 text-center d-flex flex-column justify-content-between">
                                
                                <div>
                                    <div class="mb-2">
                                        @if(prod.Nombre.ToLower().Contains("agua") || prod.Nombre.ToLower().Contains("bebida")) { <i class="bi bi-cup-straw fs-2 text-cyan opacity-75"></i> }
                                        else if(prod.Nombre.ToLower().Contains("proteina") || prod.Nombre.ToLower().Contains("suplemento")) { <i class="bi bi-capsule fs-2 text-primary opacity-75"></i> }
                                        else if(prod.Nombre.ToLower().Contains("mensualidad") || prod.Nombre.ToLower().Contains("pase")) { <i class="bi bi-ticket-perforated fs-2 text-warning opacity-75"></i> }
                                        else { <i class="bi bi-box-seam fs-2 text-white-50"></i> }
                                    </div>
                                    <h6 class="fw-bold text-white mb-1" style="font-size: 0.85rem;">@prod.Nombre</h6>
                                    <h6 class="text-primary fw-black mb-2 small">C$ @prod.PrecioVenta.ToString("N2")</h6>
                                </div>
                                
                                <div class="mt-2 d-flex flex-column gap-2">
                                    <span class="badge @(prod.StockActual > 5 ? "bg-secondary bg-opacity-25 text-white-50" : "bg-danger bg-opacity-25 text-danger") border border-secondary border-opacity-25 rounded-pill px-2 font-monospace" style="font-size: 0.7rem;">
                                        Stock: @prod.StockActual
                                    </span>
                                    
                                    <button class="btn btn-sm btn-outline-primary rounded-pill fw-bold w-100 transition-hover d-flex align-items-center justify-content-center" 
                                            @onclick="() => AgregarAlCarrito(prod)" 
                                            disabled="@(prod.StockActual <= 0)">
                                        <i class="bi bi-cart-plus me-1"></i> Agregar
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    @* LADO DERECHO: TICKET / CARRITO DE COMPRAS *@
    <div class="cart-section border border-secondary border-opacity-25 d-flex flex-column shadow-lg rounded-4 overflow-hidden" style="width: 400px; min-width: 400px; z-index: 10;">
        <div class="p-4 border-bottom border-secondary border-opacity-25 glass-panel">
            <h5 class="fw-bold text-white mb-0 tracking-wide">Ticket de Venta</h5>
        </div>

        <div class="cart-items flex-grow-1 overflow-auto custom-scrollbar p-3">
            @if (!carrito.Any())
            {
                <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted text-center opacity-50">
                    <i class="bi bi-cart-x display-1 mb-3"></i>
                    <p>El carrito está vacío<br>Selecciona productos de la izquierda</p>
                </div>
            }
            else
            {
                @foreach (var item in carrito)
                {
                    <div class="d-flex align-items-center justify-content-between mb-3 p-3 bg-secondary bg-opacity-10 rounded-4 border border-secondary border-opacity-25 slide-up">
                        <div class="flex-grow-1">
                            <h6 class="text-white fw-bold mb-1" style="font-size: 0.95rem;">@item.Producto.Nombre</h6>
                            <div class="text-primary font-monospace fw-bold small">C$ @item.Producto.PrecioVenta.ToString("N2") x @item.Cantidad</div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-sm btn-dark border-secondary rounded-circle" style="width: 30px; height: 30px;" @onclick="() => RestarCantidad(item)"><i class="bi bi-dash"></i></button>
                            <span class="text-white fw-bold font-monospace px-1">@item.Cantidad</span>
                            <button class="btn btn-sm btn-dark border-secondary rounded-circle" style="width: 30px; height: 30px;" @onclick="() => SumarCantidad(item)"><i class="bi bi-plus"></i></button>
                        </div>
                        <div class="ms-3 text-end">
                            <h6 class="text-white fw-black mb-0 font-monospace">C$ @item.Subtotal.ToString("N2")</h6>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="cart-checkout p-4 border-top border-secondary border-opacity-25">
            
            <div class="mb-3">
                <label class="form-label text-muted small fw-bold text-uppercase tracking-widest">Socio / Cliente</label>
                <select class="form-select bg-dark border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="clienteSeleccionadoId">
                    <option value="0">Público General (Sin registrar)</option>
                    @if(listaClientesActivos != null)
                    {
                        @foreach (var c in listaClientesActivos)
                        {
                            <option value="@c.Id">@c.Nombre @c.Apellido (@c.CodigoQR)</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted small fw-bold text-uppercase tracking-widest">Método de Pago</label>
                <select class="form-select bg-dark border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="metodoPagoSeleccionado">
                    <option value="Efectivo">💵 Efectivo</option>
                    <option value="Tarjeta">💳 Tarjeta / POS</option>
                    <option value="Transferencia">📱 Transferencia Móvil</option>
                </select>
            </div>
            
            <div class="d-flex justify-content-between align-items-end mb-4 border-bottom border-secondary border-opacity-25 pb-3">
                <span class="text-muted text-uppercase tracking-widest fw-bold">Total a Cobrar</span>
                <h2 class="text-primary fw-black mb-0 font-monospace">C$ @TotalCarrito.ToString("N2")</h2>
            </div>

            <button class="btn btn-gradient-primary w-100 rounded-pill py-3 fw-black fs-5 shadow-lg" disabled="@(!carrito.Any() || procesandoVenta)" @onclick="ProcesarCobro">
                @if (procesandoVenta) { <span class="spinner-border spinner-border-sm me-2"></span> }
                else { <i class="bi bi-cash-coin me-2 text-dark"></i> }
                COBRAR AHORA
            </button>
        </div>
    </div>
</div>

@* MODAL DEL RECIBO (Impresión Térmica) *@
@if (mostrarRecibo && ultimaVenta != null)
{
    <div class="modal fade show d-block fade-in" tabindex="-1" style="background-color: rgba(4, 5, 8, 0.9); backdrop-filter: blur(8px); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content bg-dark border border-secondary border-opacity-25 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-body p-0 d-flex flex-column align-items-center bg-light">
                    
                    @* --- TICKET REAL PARA IMPRESIÓN --- *@
                    <div id="ticket-impresion" class="bg-white text-dark p-3 w-100" style="max-width: 300px; font-family: 'Courier New', Courier, monospace; font-size: 12px;">
                        <div class="text-center mb-3">
                            <h4 class="fw-black mb-0">GYMIO</h4>
                            <p class="mb-0" style="font-size: 10px;">Tu Gimnasio Ideal</p>
                            <p class="mb-0" style="font-size: 10px;">Managua, Nicaragua</p>
                            <p class="mb-0 mt-2">------------------------</p>
                            <p class="mb-0 fw-bold">TICKET DE VENTA</p>
                            <p class="mb-0">Fecha: @ultimaVenta.FechaVenta.ToString("dd/MM/yyyy hh:mm tt")</p>
                            <p class="mb-0">Pago: @ultimaVenta.MetodoPago</p>
                            <p class="mb-0">Turno Caja: #@(ultimaVenta.TurnoCajaId?.ToString() ?? "N/A")</p>
                            @if(ultimaVenta.ClienteId.HasValue && ultimaVenta.ClienteId > 0)
                            {
                                var nombreCli = listaClientesActivos.FirstOrDefault(c => c.Id == ultimaVenta.ClienteId)?.Nombre;
                                <p class="mb-0">Cliente: @nombreCli</p>
                            }
                            <p class="mb-0">------------------------</p>
                        </div>

                        <table class="w-100 mb-2">
                            <thead>
                                <tr class="border-bottom border-dark">
                                    <th class="text-start pb-1">CANT</th>
                                    <th class="text-start pb-1">DESCRIP</th>
                                    <th class="text-end pb-1">SUBT</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var det in ultimaVenta.Detalles)
                                {
                                    <tr>
                                        <td class="text-start pt-1">@det.Cantidad</td>
                                        <td class="text-start pt-1">@det.Concepto</td>
                                        <td class="text-end pt-1">@det.Subtotal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="text-center">
                            <p class="mb-0">------------------------</p>
                            <h5 class="fw-bold mt-2">TOTAL: C$ @ultimaVenta.Total.ToString("N2")</h5>
                            <p class="mb-0">------------------------</p>
                            <p class="mt-3 mb-0" style="font-size: 10px;">¡Gracias por tu compra!</p>
                            <p class="mb-0" style="font-size: 10px;">El esfuerzo de hoy es</p>
                            <p class="mb-0" style="font-size: 10px;">el éxito de mañana.</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 p-3 bg-dark d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-secondary rounded-pill fw-bold px-4" @onclick="CerrarRecibo">Cerrar</button>
                    <button type="button" class="btn btn-gradient-primary rounded-pill fw-bold px-4 text-dark" @onclick="ImprimirTicket">
                        <i class="bi bi-printer-fill me-2"></i> Imprimir
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* =========================================
       ESTILOS DE LA PANTALLA (PUNTO DE VENTA)
       ========================================= */
    .pos-container { 
        background: transparent; 
        font-family: 'Segoe UI', Roboto, sans-serif;
        min-height: calc(100vh - 7rem);
        width: 100%;
    }

    .products-section, .cart-section {
        background-color: #0f141e;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 1rem;
        box-shadow: 0 14px 30px rgba(0, 0, 0, 0.18);
    }

    .cart-section, .cart-checkout, .glass-panel {
        background-color: #0f141e !important;
    }

    .product-card, .cart-items .bg-secondary {
        background-color: #111827 !important;
    }

    .btn-gradient-primary { background: linear-gradient(135deg, #00FFA3, #00B8D4); color: #000 !important; border: none; }
    .btn-gradient-primary:hover:not(:disabled) { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0, 255, 163, 0.4) !important; }
    .btn-gradient-primary:disabled { opacity: 0.6; cursor: not-allowed; }
    
    .btn-outline-primary { color: #00FFA3; border-color: rgba(0, 255, 163, 0.5); }
    .btn-outline-primary:hover:not(:disabled) { background-color: #00FFA3; color: #040508; border-color: #00FFA3; }
    .btn-outline-primary:disabled { color: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.1); cursor: not-allowed; }

    .text-primary { color: #00FFA3 !important; }
    .text-cyan { color: #00B8D4 !important; }
    
    .glass-panel { backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); }
    .product-card { border: 1px solid rgba(255,255,255,0.03) !important; }
    .transition-hover { transition: all 0.2s ease; }

    .form-control:focus, .form-select:focus { background-color: rgba(255,255,255,0.05) !important; color: white !important; border-color: #00FFA3 !important; box-shadow: 0 0 10px rgba(0, 255, 163, 0.2) !important; }

    .fade-in { animation: fadeIn 0.4s ease-in-out; }
    .slide-up { animation: slideUp 0.3s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(0, 255, 163, 0.5); }
    
    .tracking-widest { letter-spacing: 0; }
    .tracking-wide { letter-spacing: 0; }

    @@media (max-width: 992px) {
        .pos-container { flex-direction: column; overflow: visible !important; }
        .cart-section { width: 100% !important; min-width: 0 !important; }
    }

    /* =========================================
       MAGIA PARA IMPRESIÓN (Térmica y Normal)
       ========================================= */
    @@media print {
        .pos-container, header, nav, .sidebar { 
            display: none !important; 
        }
        
        .modal {
            position: static !important;
            display: block !important;
            overflow: visible !important;
            background: transparent !important;
        }
        .modal-dialog, .modal-content, .modal-body {
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
            box-shadow: none !important;
            width: 100% !important;
            max-width: 100% !important;
            background: transparent !important;
        }

        .modal-footer, .modal-backdrop { 
            display: none !important; 
        }

        #ticket-impresion { 
            width: 80mm !important; 
            margin: 0 !important;
            padding: 0 !important;
            color: black !important;
            background-color: white !important;
        }
    }
</style>

@code {
    private int idCajeroActual;
    private TurnoCaja? turnoActivo = null; // NUEVO: Para guardar el turno abierto

    private bool productosCargando = true;
    private bool procesandoVenta = false;
    
    private List<Cliente> listaClientesActivos = new();
    private int clienteSeleccionadoId = 0;
    private string metodoPagoSeleccionado = "Efectivo";
    
    private bool mostrarRecibo = false;
    private Venta? ultimaVenta = null;

    private string _filtroBusqueda = "";
    private string filtroBusqueda 
    {
        get => _filtroBusqueda;
        set { _filtroBusqueda = value; StateHasChanged(); }
    }

    private List<Producto> catalogoProductos = new();
    private List<Producto> productosFiltrados => string.IsNullOrWhiteSpace(filtroBusqueda) 
        ? catalogoProductos 
        : catalogoProductos.Where(p => p.Nombre.Contains(filtroBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();

    private class ItemCarrito 
    {
        public Producto Producto { get; set; } = new();
        public int Cantidad { get; set; }
        public decimal Subtotal => Producto.PrecioVenta * Cantidad;
    }

    private List<ItemCarrito> carrito = new();
    private decimal TotalCarrito => carrito.Sum(i => i.Subtotal);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            if (int.TryParse(user.FindFirst(ClaimTypes.NameIdentifier)?.Value, out int uid))
            {
                idCajeroActual = uid;
            }
        }

        // NUEVO: Verificamos que el empleado tenga un turno abierto ANTES de dejarlo vender
        turnoActivo = await CajaService.ObtenerTurnoActivoAsync(idCajeroActual);
        
        if (turnoActivo == null)
        {
            // Si la caja está cerrada, lo pateamos a la pantalla de abrir caja
            Navigation.NavigateTo("/caja");
            return;
        }

        await CargarCatalogo();
        
        var todosLosClientes = await ClienteService.ObtenerClientesAsync("");
        listaClientesActivos = todosLosClientes.Where(c => c.Activo).ToList();
    }

    private async Task CargarCatalogo()
    {
        productosCargando = true;
        catalogoProductos = await VentaService.ObtenerProductosActivosAsync();
        productosCargando = false;
    }

    private void AgregarAlCarrito(Producto prod)
    {
        if (prod.StockActual <= 0) return; 
        
        var itemExistente = carrito.FirstOrDefault(i => i.Producto.Id == prod.Id);
        
        if (itemExistente != null)
        {
            if (itemExistente.Cantidad < prod.StockActual) itemExistente.Cantidad++;
        }
        else
        {
            carrito.Add(new ItemCarrito { Producto = prod, Cantidad = 1 });
        }
    }

    private void SumarCantidad(ItemCarrito item)
    {
        if (item.Cantidad < item.Producto.StockActual) item.Cantidad++;
    }

    private void RestarCantidad(ItemCarrito item)
    {
        if (item.Cantidad > 1) item.Cantidad--;
        else carrito.Remove(item);
    }

    private async Task ProcesarCobro()
    {
        // Por seguridad extra (por si acaso el turno se cerró mientras estaba eligiendo productos)
        if (turnoActivo == null) return; 

        procesandoVenta = true;
        
        try 
        {
            var nuevaVenta = new Venta
            {
                UsuarioId = idCajeroActual,
                ClienteId = clienteSeleccionadoId > 0 ? clienteSeleccionadoId : null, 
                
                // NUEVO: ¡Aquí ocurre la magia! Le pasamos el ID del Turno a la Venta
                TurnoCajaId = turnoActivo.Id,

                FechaVenta = DateTime.Now,
                Total = TotalCarrito,
                MetodoPago = metodoPagoSeleccionado,
                Detalles = carrito.Select(item => new VentaDetalle
                {
                    Concepto = item.Producto.Nombre,
                    Cantidad = item.Cantidad,
                    ProductoId = item.Producto.Id,
                    PrecioUnitario = item.Producto.PrecioVenta,
                    Subtotal = item.Subtotal
                }).ToList()
            };

            await VentaService.CrearVentaAsync(nuevaVenta);
            
            ultimaVenta = nuevaVenta;
            mostrarRecibo = true; 
            
            carrito.Clear();
            clienteSeleccionadoId = 0; 
            
            await CargarCatalogo();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cobrar: {ex.Message}");
        }
        finally
        {
            procesandoVenta = false;
        }
    }

    private async Task ImprimirTicket()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private void CerrarRecibo()
    {
        mostrarRecibo = false;
        ultimaVenta = null;
    }
}
