@page "/reportes"
@attribute [Authorize(Roles = "Administrador")]
@rendermode InteractiveServer

@using Gymio.Models
@using Gymio.Interfaces
@using Gymio.Services
@inject IVentaService VentaService

<PageTitle>Reportes Estadísticos - Gymio</PageTitle>

<div class="page-container p-4 fade-in">
    
    @* ENCABEZADO *@
    <div class="mb-4">
        <h2 class="fw-black text-white mb-0"><i class="bi bi-bar-chart-line-fill text-primary me-2"></i> Inteligencia de Negocios</h2>
        <span class="text-muted small tracking-widest text-uppercase">Análisis y Estadísticas del Gimnasio</span>
    </div>

    <div class="row g-4">
        @* GRÁFICO 1: INGRESOS FINANCIEROS *@
        <div class="col-12 col-xl-8">
            <div class="card bg-dark border-secondary border-opacity-25 rounded-4 shadow-lg p-4 h-100">
                <h5 class="text-white fw-bold mb-4 tracking-widest text-uppercase" style="font-size: 0.9rem;">
                    <i class="bi bi-currency-dollar text-success me-2"></i> Rendimiento Financiero (Últimos 6 Meses)
                </h5>
                
                @if (ingresosHistoricos == null)
                {
                    <div class="d-flex justify-content-center align-items-center h-100 py-5">
                        <div class="spinner-border text-primary"></div>
                    </div>
                }
                else
                {
                   

                    <RadzenChart>
                        <RadzenLineSeries Smooth="true" Data="@ingresosHistoricos" CategoryProperty="Mes" Title="Ingresos Totales (C$)" ValueProperty="Total" Stroke="#00FFA3">
                            <RadzenMarkers MarkerType="MarkerType.Circle" Fill="#00FFA3" Stroke="#fff" StrokeWidth="2" Size="5" />
                            <RadzenSeriesDataLabels Visible="true" />
                        </RadzenLineSeries>
                        <RadzenCategoryAxis Padding="20" />
                        <RadzenValueAxis>
                            <RadzenGridLines Visible="true" Stroke="rgba(255,255,255,0.05)" />
                            <RadzenAxisTitle Text="Monto en Córdobas" />
                        </RadzenValueAxis>
                        <RadzenLegend Position="LegendPosition.Bottom" />
                        <RadzenTooltipOptions Style="background-color: #0f141e; border: 1px solid #00FFA3; color: white;" />
                    </RadzenChart>
                }
            </div>
        </div>

        @* ESPACIO PARA EL GRÁFICO 2 (Lo haremos en el paso 2) *@
        <div class="col-12 col-xl-4">
            <div class="card bg-dark border-secondary border-opacity-25 rounded-4 shadow-lg p-4 h-100 d-flex align-items-center justify-content-center text-center">
                <i class="bi bi-pie-chart-fill display-1 text-muted opacity-25 mb-3"></i>
                <h6 class="text-muted fw-bold tracking-widest text-uppercase">Espacio Reservado</h6>
                <p class="small text-muted mb-0">Aquí irá el próximo gráfico</p>
            </div>
        </div>
    </div>
</div>

<style>
    .page-container { font-family: 'Segoe UI', Roboto, sans-serif; }
    .tracking-widest { letter-spacing: 0.15em; }
    .text-primary { color: #00FFA3 !important; }
    
    .fade-in { animation: fadeIn 0.4s ease-in-out; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    /* Ajustes para forzar el tema oscuro en Radzen si no tenés el CSS dark cargado a nivel global */
    .rz-chart { background-color: transparent !important; }
    .rz-chart text { fill: #a0aabf !important; font-family: 'Segoe UI', Roboto, sans-serif !important; }
    .rz-grid-line { stroke: rgba(255, 255, 255, 0.05) !important; }
</style>

@code {
    private List<IngresoMensual>? ingresosHistoricos;

    protected override async Task OnInitializedAsync()
    {
        ingresosHistoricos = await VentaService.GetIngresosUltimos6MesesAsync();
    }
}