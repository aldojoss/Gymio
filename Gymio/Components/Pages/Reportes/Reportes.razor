@page "/reportes"
@attribute [Authorize(Roles = "Administrador")]
@rendermode InteractiveServer

@using Gymio.Models
@using Gymio.Interfaces
@using Gymio.DTOs
@using Gymio.Services
@inject IVentaService VentaService
@inject IClienteService ClienteService

<PageTitle>Inteligencia de Negocios - Gymio</PageTitle>

<div class="page-container p-4 fade-in">
    
    <div class="mb-4 d-flex justify-content-between align-items-end">
        <div>
            <h2 class="fw-black text-white mb-0"><i class="bi bi-bar-chart-line-fill text-primary me-2"></i> Inteligencia de Negocios</h2>
            <span class="text-muted small tracking-widest text-uppercase">Análisis y Estadísticas del Gimnasio</span>
        </div>
        <button class="btn btn-outline-primary rounded-pill px-4" @onclick="CargarDatos">
            <i class="bi bi-arrow-clockwise me-2"></i> Actualizar
        </button>
    </div>

    @if (cargando)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card bg-dark border-success border-opacity-25 shadow-lg h-100 rounded-4 p-2 slide-up" style="animation-delay: 0.1s;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="text-muted text-uppercase tracking-widest small fw-bold mb-0">Ingresos Brutos</h6>
                            <div class="bg-success bg-opacity-10 text-success rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-arrow-up-right fs-5"></i>
                            </div>
                        </div>
                        <h3 class="text-success fw-black mb-1">C$ @resumenMes.Ingresos.ToString("N2")</h3>
                        <span class="text-muted small">Mes en curso</span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card bg-dark border-danger border-opacity-25 shadow-lg h-100 rounded-4 p-2 slide-up" style="animation-delay: 0.2s;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="text-muted text-uppercase tracking-widest small fw-bold mb-0">Egresos Operativos</h6>
                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-arrow-down-right fs-5"></i>
                            </div>
                        </div>
                        <h3 class="text-danger fw-black mb-1">C$ @resumenMes.Egresos.ToString("N2")</h3>
                        <span class="text-muted small">Planilla y compras</span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card bg-dark border-primary border-opacity-25 shadow-lg h-100 rounded-4 p-2 slide-up" style="animation-delay: 0.3s;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="text-muted text-uppercase tracking-widest small fw-bold mb-0">Utilidad Neta</h6>
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-wallet2 fs-5"></i>
                            </div>
                        </div>
                        <h3 class="text-primary fw-black mb-1">C$ @((resumenMes.Ingresos - resumenMes.Egresos).ToString("N2"))</h3>
                        <span class="text-muted small">Balance mensual</span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card bg-dark border-info border-opacity-25 shadow-lg h-100 rounded-4 p-2 slide-up" style="animation-delay: 0.4s;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="text-muted text-uppercase tracking-widest small fw-bold mb-0">Tasa de Retención</h6>
                            <div class="bg-info bg-opacity-10 text-info rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-people fs-5"></i>
                            </div>
                        </div>
                        <h3 class="text-info fw-black mb-1">@estadisticaPoblacion.ClientesActivos <span class="fs-6 text-muted fw-normal">/ @estadisticaPoblacion.TotalClientes</span></h3>
                        <span class="text-muted small">Atletas con plan activo</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-12 col-xl-8">
                <div class="card bg-dark border-secondary border-opacity-25 rounded-4 shadow-lg p-4 h-100 slide-up" style="animation-delay: 0.5s;">
                    <h5 class="text-white fw-bold mb-4 tracking-widest text-uppercase" style="font-size: 0.9rem;">
                        <i class="bi bi-graph-up text-success me-2"></i> Rendimiento Financiero (Últimos 6 Meses)
                    </h5>
                    
                    @if (ingresosHistoricos == null || !ingresosHistoricos.Any())
                    {
                        <div class="text-muted text-center py-5">No hay datos históricos suficientes.</div>
                    }
                    else
                    {
                        <RadzenChart>
                            <RadzenLineSeries Smooth="true" Data="@ingresosHistoricos" CategoryProperty="Mes" Title="Ingresos (C$)" ValueProperty="Total" Stroke="#00FFA3">
                                <RadzenMarkers MarkerType="MarkerType.Circle" Fill="#00FFA3" Stroke="#fff" StrokeWidth="2" Size="5" />
                                <RadzenSeriesDataLabels Visible="true" />
                            </RadzenLineSeries>
                            <RadzenValueAxis Formatter="@(value => string.Format("{0:N0}", value))">
    <RadzenGridLines Visible="true" Stroke="rgba(255,255,255,0.05)" />
</RadzenValueAxis>
                            <RadzenLegend Position="LegendPosition.Bottom" />
                            <RadzenTooltipOptions Style="background-color: #0f141e; border: 1px solid #00FFA3; color: white;" />
                        </RadzenChart>
                    }
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="card bg-dark border-secondary border-opacity-25 rounded-4 shadow-lg p-4 h-100 slide-up" style="animation-delay: 0.6s;">
                    <h5 class="text-white fw-bold mb-4 tracking-widest text-uppercase" style="font-size: 0.9rem;">
                        <i class="bi bi-pie-chart-fill text-warning me-2"></i> Rotación de Inventario (Top 5)
                    </h5>
                    
                    @if (topProductos == null || !topProductos.Any())
                    {
                        <div class="text-muted text-center py-5">No hay ventas registradas.</div>
                    }
                    else
                    {
                        <RadzenChart>
                           <RadzenPieSeries Data="@topProductos" Title="Unidades" CategoryProperty="NombreProducto" ValueProperty="CantidadVendida"
                 Fills=@(new [] { "#ffc107", "#00FFA3", "#00B8D4", "#f43f5e", "#8b5cf6" })>
                                <RadzenSeriesDataLabels Visible="true" />
                            </RadzenPieSeries>
                            <RadzenLegend Position="LegendPosition.Bottom" />
                            <RadzenTooltipOptions Style="background-color: #0f141e; border: 1px solid #ffc107; color: white;" />
                        </RadzenChart>
                    }
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12">
                <div class="card bg-dark border-secondary border-opacity-25 rounded-4 shadow-lg p-4 slide-up" style="animation-delay: 0.7s;">
                    <h5 class="text-white fw-bold mb-4 tracking-widest text-uppercase" style="font-size: 0.9rem;">
                        <i class="bi bi-receipt text-info me-2"></i> Últimos Movimientos Contables
                    </h5>
                    
                    <div class="table-responsive">
                        <table class="table table-dark table-borderless table-hover align-middle mb-0">
                            <thead>
                                <tr class="text-muted small text-uppercase tracking-widest border-bottom border-secondary border-opacity-25">
                                    <th class="pb-3">Fecha</th>
                                    <th class="pb-3">Tipo</th>
                                    <th class="pb-3">Concepto</th>
                                    <th class="text-end pb-3">Monto</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (transaccionesRecientes != null && transaccionesRecientes.Any())
                                {
                                    @foreach (var tran in transaccionesRecientes)
                                    {
                                        <tr>
                                            <td class="py-3 text-white-50">@tran.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="py-3">
                                                @if(tran.EsIngreso)
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">Ingreso</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2">Egreso</span>
                                                }
                                            </td>
                                            <td class="py-3 text-white">@tran.Concepto</td>
                                            <td class="text-end py-3 font-monospace fw-bold @(tran.EsIngreso ? "text-success" : "text-danger")">
                                                @(tran.EsIngreso ? "+" : "-") C$ @tran.Monto.ToString("N2")
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">No hay movimientos recientes.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .page-container { font-family: 'Segoe UI', Roboto, sans-serif; background-color: #040508; min-height: 100vh; margin: -1.5rem; padding: 1.5rem; width: calc(100% + 3rem); }
    .tracking-widest { letter-spacing: 0.15em; }
    .text-primary { color: #00FFA3 !important; }
    
    .fade-in { animation: fadeIn 0.4s ease-in-out; }
    .slide-up { animation: slideUp 0.5s ease-out forwards; opacity: 0; transform: translateY(20px); }
    
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { to { opacity: 1; transform: translateY(0); } }

    .rz-chart { background-color: transparent !important; }
    .rz-chart text { fill: #a0aabf !important; font-family: 'Segoe UI', Roboto, sans-serif !important; }
    .rz-grid-line { stroke: rgba(255, 255, 255, 0.05) !important; }
    
    .table-hover tbody tr:hover { background-color: rgba(255, 255, 255, 0.02) !important; }
</style>

@code {
    private bool cargando = true;

    private ResumenFinancieroDto resumenMes = new();
    private EstadisticaPoblacionDto estadisticaPoblacion = new();
    private List<IngresoMensual> ingresosHistoricos = new();
    private List<ProductoTop> topProductos = new();
    private List<TransaccionFinancieraDto> transaccionesRecientes = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        
        try
        {
            ingresosHistoricos = await VentaService.GetIngresosUltimos6MesesAsync() ?? new List<IngresoMensual>();
            resumenMes = await VentaService.GetResumenFinancieroMesActualAsync() ?? new ResumenFinancieroDto();
            topProductos = await VentaService.GetTopProductosVendidosAsync(5) ?? new List<ProductoTop>();
            transaccionesRecientes = await VentaService.GetUltimosMovimientosFinancierosAsync(8) ?? new List<TransaccionFinancieraDto>();
            
            var totalCli = await ClienteService.GetTotalClientesAsync();
            var activosCli = await ClienteService.GetTotalClientesActivosAsync();
            estadisticaPoblacion = new EstadisticaPoblacionDto { TotalClientes = totalCli, ClientesActivos = activosCli };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar el Dashboard: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

   

    
}