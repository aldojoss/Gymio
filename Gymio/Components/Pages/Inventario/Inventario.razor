@page "/inventario"
@attribute [Authorize(Roles = "Administrador, Empleado")]
@rendermode InteractiveServer

@using Gymio.Models
@using Gymio.Interfaces
@inject IProductoService ProductoService

<PageTitle>Inventario - Gymio</PageTitle>

<div class="page-container p-4 fade-in">
    
    @* ENCABEZADO *@
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-black text-white mb-0">Gestión de Inventario</h2>
            <span class="text-muted small tracking-widest text-uppercase">Productos y precios</span>
        </div>
        
        <div class="d-flex gap-3 align-items-center w-100" style="max-width: 600px;">
            <div class="input-group bg-dark border border-secondary border-opacity-25 rounded-pill overflow-hidden shadow-sm flex-grow-1">
                <span class="input-group-text bg-transparent border-0 text-muted ps-4">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control bg-transparent border-0 text-white shadow-none py-2" 
                       placeholder="Buscar producto..." 
                       @bind="filtroBusqueda" @bind:event="oninput" />
            </div>

            <button class="btn btn-gradient rounded-pill px-4 py-2 fw-bold shadow-sm transition-hover text-nowrap" @onclick="AbrirModalNuevo">
                <i class="bi bi-plus-lg me-2"></i> Nuevo Producto
            </button>
        </div>
    </div>

    @* TABLA DE PRODUCTOS *@
    <div class="table-responsive custom-scrollbar pb-3">
        <table class="table modern-table table-borderless align-middle mb-0" style="min-width: 900px;">
            <thead>
                <tr class="text-muted text-uppercase small tracking-widest" style="font-size: 0.75rem;">
                    <th class="ps-4 pb-3">Producto</th>
                    <th class="pb-3 text-center">Costo (C$)</th>
                    <th class="pb-3 text-center">Precio Venta (C$)</th>
                    <th class="pb-3 text-center">Stock</th>
                    <th class="pb-3 text-center">Estado</th>
                    <th class="text-end pe-4 pb-3">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (listaProductos == null)
                {
                    <tr><td colspan="6" class="text-center py-5 text-muted"><div class="spinner-border text-primary"></div></td></tr>
                }
                else if (!productosFiltrados.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <div class="bg-dark d-inline-block p-4 rounded-circle mb-3"><i class="bi bi-box-seam display-4 text-white-50"></i></div>
                            <h5 class="text-white">Sin resultados</h5>
                            <p class="small">No hay productos que coincidan con la búsqueda.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var prod in productosFiltrados)
                    {
                        <tr class="modern-row slide-up">
                            <td class="ps-4 py-3 rounded-start-4">
                                <div class="fw-bold text-white" style="font-size: 1.05rem;">@prod.Nombre</div>
                            </td>
                            <td class="py-3 text-center text-white-50 font-monospace">@prod.PrecioCompra.ToString("N2")</td>
                            <td class="py-3 text-center text-primary fw-bold font-monospace">@prod.PrecioVenta.ToString("N2")</td>
                            <td class="py-3 text-center">
                                <span class="badge @(prod.StockActual > 5 ? "bg-dark text-white-50" : "bg-danger bg-opacity-25 text-danger") border border-secondary border-opacity-25 rounded-pill px-3 font-monospace">
                                    @prod.StockActual
                                </span>
                            </td>
                            <td class="py-3 text-center">
                                @if (prod.Activo)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 fw-normal">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 fw-normal">Inactivo</span>
                                }
                            </td>
                            <td class="text-end pe-4 py-3 rounded-end-4">
                                <button class="btn btn-sm btn-outline-info fw-bold rounded-pill px-3 transition-hover" @onclick="() => AbrirModalEdicion(prod)">
                                    <i class="bi bi-pencil me-1"></i> Editar
                                </button>
                            </td>
                        </tr>
                        <tr class="row-spacer"><td colspan="6"></td></tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* MODAL CREAR / EDITAR *@
@if (mostrarModal)
{
    <div class="modal fade show d-block fade-in" tabindex="-1" style="background-color: rgba(4, 5, 8, 0.8); backdrop-filter: blur(8px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border border-secondary border-opacity-25 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-header border-bottom border-secondary border-opacity-25 p-4">
                    <h5 class="modal-title fw-black text-white d-flex align-items-center">
                        <div class="bg-gradient-primary rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="bi bi-box text-dark fs-5"></i>
                        </div>
                        @(esEdicion ? "Editar Producto" : "Nuevo Producto")
                    </h5>
                    <button type="button" class="btn-close btn-close-white opacity-50 shadow-none" @onclick="CerrarModal"></button>
                </div>
                
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Nombre del Producto</label>
                            <input type="text" class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="productoActual.Nombre" placeholder="Ej: Agua, Toalla, Mensualidad..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Costo Compra (C$)</label>
                            <input type="number" class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="productoActual.PrecioCompra" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Precio Venta (C$)</label>
                            <input type="number" class="form-control bg-transparent border-primary border-opacity-50 text-white shadow-none rounded-3" @bind="productoActual.PrecioVenta" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Stock Inicial</label>
                            <input type="number" class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="productoActual.StockActual" disabled="@esEdicion" />
                            @if(esEdicion) { <small class="text-muted" style="font-size: 0.7rem;">El stock se ajusta desde el módulo de Compras.</small> }
                        </div>
                        <div class="col-12 mt-4">
                            <div class="form-check form-switch p-3 rounded-3 border border-secondary border-opacity-25" style="background-color: rgba(255,255,255,0.02);">
                                <input class="form-check-input ms-0 me-3" type="checkbox" id="estadoProd" @bind="productoActual.Activo" style="transform: scale(1.3);">
                                <label class="form-check-label fw-bold text-white mt-1" for="estadoProd">
                                    @(productoActual.Activo ? "Producto Activo (Visible en Caja)" : "Producto Inactivo (Oculto)")
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="modal-footer border-top border-secondary border-opacity-25 p-4" style="background-color: rgba(255,255,255,0.02);">
                    <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold px-4" @onclick="CerrarModal">Cancelar</button>
                    <button type="button" class="btn btn-gradient fw-bold rounded-pill px-4 shadow-sm" @onclick="GuardarProducto">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .page-container { font-family: 'Segoe UI', Roboto, sans-serif; }
    .bg-gradient-primary { background: linear-gradient(135deg, #00FFA3, #00B8D4); }
    .text-primary { color: #00FFA3 !important; }
    
    .btn-gradient { background: linear-gradient(135deg, #00FFA3, #00B8D4); color: #040508; border: none; }
    .btn-gradient:hover { filter: brightness(1.1); color: #040508; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0, 255, 163, 0.3) !important; }

    .modern-table { border-collapse: separate; border-spacing: 0; }
    .modern-row td { background-color: #0f141e; border-top: 1px solid rgba(255, 255, 255, 0.02); border-bottom: 1px solid rgba(255, 255, 255, 0.02); transition: all 0.2s ease; }
    .modern-row td:first-child { border-left: 1px solid rgba(255, 255, 255, 0.02); }
    .modern-row td:last-child { border-right: 1px solid rgba(255, 255, 255, 0.02); }
    .row-spacer td { height: 10px; padding: 0; background: transparent; border: none; }
    .modern-row:hover td { background-color: #161d2b; transform: scale(1.005); }

    .form-control:focus { background-color: rgba(255,255,255,0.05) !important; border-color: #00FFA3 !important; color: white !important; box-shadow: 0 0 0 0.25rem rgba(0, 255, 163, 0.25) !important; }
    .form-switch .form-check-input:checked { background-color: #00FFA3; border-color: #00FFA3; }
    .btn-outline-info { color: #00B8D4; border-color: rgba(0, 184, 212, 0.5); }
    .btn-outline-info:hover { background-color: #00B8D4; color: #040508; border-color: #00B8D4; }

    .tracking-widest { letter-spacing: 0.1em; }
    .fade-in { animation: fadeIn 0.3s ease-in-out; }
    .slide-up { animation: slideUp 0.3s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private List<Producto>? listaProductos;
    
    // Variables para el buscador en tiempo real
    private string _filtroBusqueda = "";
    private string filtroBusqueda 
    {
        get => _filtroBusqueda;
        set { _filtroBusqueda = value; StateHasChanged(); }
    }

    // Lista dinámica que reacciona a lo que tecleás
    private List<Producto> productosFiltrados => 
        string.IsNullOrWhiteSpace(filtroBusqueda) || listaProductos == null
            ? (listaProductos ?? new List<Producto>())
            : listaProductos.Where(p => p.Nombre.Contains(filtroBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();

    private bool mostrarModal = false;
    private bool esEdicion = false;
    private Producto productoActual = new Producto();

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        // Solo molesta a la base de datos cuando carga la página o guardás un cambio
        listaProductos = await ProductoService.ObtenerProductosAsync("");
    }

    private void AbrirModalNuevo()
    {
        esEdicion = false;
        productoActual = new Producto { Activo = true };
        mostrarModal = true;
    }

    private void AbrirModalEdicion(Producto prod)
    {
        esEdicion = true;
        productoActual = new Producto
        {
            Id = prod.Id,
            Nombre = prod.Nombre,
            PrecioCompra = prod.PrecioCompra,
            PrecioVenta = prod.PrecioVenta,
            StockActual = prod.StockActual,
            Activo = prod.Activo
        };
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
    }

    private async Task GuardarProducto()
    {
        if (string.IsNullOrWhiteSpace(productoActual.Nombre) || productoActual.PrecioVenta <= 0) return;

        if (esEdicion)
        {
            await ProductoService.ActualizarProductoAsync(productoActual);
        }
        else
        {
            await ProductoService.CrearProductoAsync(productoActual);
        }

        await CargarProductos();
        mostrarModal = false;
    }
}