@page "/egresos"
@attribute [Authorize(Roles = "Administrador,Empleado")]
@rendermode InteractiveServer

@using Gymio.Models
@using Gymio.Interfaces
@using System.Security.Claims
@inject IEgresoService EgresoService
@inject ITurnoCajaService CajaService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Egresos - Gymio</PageTitle>

<div class="page-container p-4 fade-in">
    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center mb-4 gap-3">
        <div>
            <h2 class="fw-black text-white mb-0"><i class="bi bi-cart-dash text-danger me-2"></i> Egresos</h2>
            <span class="text-muted small tracking-widest text-uppercase">Salidas de dinero y gastos operativos</span>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center">
            @if (turnoActivo != null)
            {
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 fw-bold">
                    <i class="bi bi-unlock-fill me-1"></i> Caja #@turnoActivo.Id abierta
                </span>
            }
            else
            {
                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3 py-2 fw-bold">
                    <i class="bi bi-lock-fill me-1"></i> Sin caja abierta
                </span>
            }

            <button class="btn btn-outline-info rounded-pill px-4 fw-bold transition-hover" @onclick='() => Navigation.NavigateTo("/caja")'>
                <i class="bi bi-cash-stack me-2"></i> Control de Caja
            </button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="d-flex justify-content-center align-items-center py-5">
            <div class="spinner-border text-danger" role="status" style="width: 3rem; height: 3rem;"></div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="metric-card border-danger">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="metric-label text-danger">Egresos del periodo</div>
                            <h3 class="text-white fw-black mb-0">C$ @TotalPeriodo.ToString("N2")</h3>
                        </div>
                        <i class="bi bi-graph-down-arrow fs-2 text-danger"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="metric-card border-warning">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="metric-label text-warning">Registrados hoy</div>
                            <h3 class="text-white fw-black mb-0">C$ @TotalHoy.ToString("N2")</h3>
                        </div>
                        <i class="bi bi-calendar2-day fs-2 text-warning"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="metric-card border-info">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="metric-label text-info">Descontado del turno</div>
                            <h3 class="text-white fw-black mb-0">C$ @TotalTurnoActivo.ToString("N2")</h3>
                        </div>
                        <i class="bi bi-safe2 fs-2 text-info"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-4">
                <div class="panel-surface h-100">
                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-circle bg-danger bg-opacity-10 text-danger me-3">
                            <i class="bi bi-receipt-cutoff fs-4"></i>
                        </div>
                        <div>
                            <h5 class="text-white fw-black mb-0">Nuevo egreso</h5>
                            <span class="text-muted small">Registrado por @nombreUsuario</span>
                        </div>
                    </div>

                    @if (turnoActivo == null)
                    {
                        <div class="alert alert-warning bg-warning bg-opacity-10 border-warning border-opacity-25 text-warning rounded-3 small">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            Abre caja antes de registrar salidas de dinero para que el cierre cuadre correctamente.
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label text-muted tracking-widest text-uppercase small fw-bold">Categoría</label>
                        <select class="form-select bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="nuevoEgreso.CategoriaEgresoId">
                            @foreach (var categoria in categorias)
                            {
                                <option value="@categoria.Id" class="text-dark">@categoria.Nombre</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted tracking-widest text-uppercase small fw-bold">Concepto</label>
                        <input class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="nuevoEgreso.Concepto" placeholder="Ej: compra de limpieza" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted tracking-widest text-uppercase small fw-bold">Monto</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark text-danger border-secondary border-opacity-50 fw-bold">C$</span>
                            <input type="number" min="0" step="0.01" class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="nuevoEgreso.Monto" />
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(mensajeError))
                    {
                        <div class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger rounded-3 small">
                            <i class="bi bi-x-circle-fill me-2"></i> @mensajeError
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(mensajeExito))
                    {
                        <div class="alert alert-success bg-success bg-opacity-10 border-success text-success rounded-3 small">
                            <i class="bi bi-check-circle-fill me-2"></i> @mensajeExito
                        </div>
                    }

                    <button class="btn btn-danger w-100 rounded-pill py-3 fw-black shadow-sm transition-hover" @onclick="RegistrarEgreso" disabled="@(guardando || turnoActivo == null)">
                        @if (guardando)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-save-fill me-2"></i>
                        }
                        Registrar salida
                    </button>
                </div>
            </div>

            <div class="col-xl-8">
                <div class="panel-surface">
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
                        <div>
                            <h5 class="text-white fw-black mb-0">Historial de egresos</h5>
                            <span class="text-muted small">Últimos movimientos por categoría y caja</span>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <input type="date" class="form-control filter-control" @bind="fechaDesde" />
                            <input type="date" class="form-control filter-control" @bind="fechaHasta" />
                            <select class="form-select filter-control" @bind="filtroCategoriaId">
                                <option value="0">Todas</option>
                                @foreach (var categoria in categorias)
                                {
                                    <option value="@categoria.Id">@categoria.Nombre</option>
                                }
                            </select>
                            <div class="input-group filter-search">
                                <span class="input-group-text bg-transparent border-secondary border-opacity-25 text-muted"><i class="bi bi-search"></i></span>
                                <input class="form-control bg-transparent border-secondary border-opacity-25 text-white shadow-none" placeholder="Buscar..." @bind="filtroBusqueda" @bind:event="oninput" />
                            </div>
                            <button class="btn btn-outline-info rounded-pill px-3 fw-bold" @onclick="CargarDatos">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive custom-scrollbar pb-2">
                        <table class="table modern-table table-borderless align-middle mb-0" style="min-width: 850px;">
                            <thead>
                                <tr class="text-muted text-uppercase small tracking-widest" style="font-size: 0.75rem;">
                                    <th class="ps-4 pb-3">Fecha</th>
                                    <th class="pb-3">Concepto</th>
                                    <th class="pb-3">Categoría</th>
                                    <th class="pb-3">Caja</th>
                                    <th class="pb-3">Registró</th>
                                    <th class="text-end pe-4 pb-3">Monto</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!egresos.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">
                                            <i class="bi bi-receipt display-5 text-white-50 d-block mb-3"></i>
                                            No hay egresos para los filtros seleccionados.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var egreso in egresos)
                                    {
                                        <tr class="modern-row slide-up">
                                            <td class="ps-4 py-3 rounded-start-4 text-white-50">@egreso.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="py-3">
                                                <div class="text-white fw-bold">@egreso.Concepto</div>
                                            </td>
                                            <td class="py-3">
                                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2">
                                                    @(egreso.Categoria?.Nombre ?? "Sin categoría")
                                                </span>
                                            </td>
                                            <td class="py-3 text-white-50">
                                                @(egreso.TurnoCajaId.HasValue ? $"#{egreso.TurnoCajaId}" : "General")
                                            </td>
                                            <td class="py-3 text-white-50">@(egreso.UsuarioRegistra?.NombreCompleto ?? $"Usuario #{egreso.UsuarioId}")</td>
                                            <td class="text-end pe-4 py-3 rounded-end-4 font-monospace fw-black text-danger">
                                                - C$ @egreso.Monto.ToString("N2")
                                            </td>
                                        </tr>
                                        <tr class="row-spacer"><td colspan="6"></td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .page-container { font-family: 'Segoe UI', Roboto, sans-serif; }
    .fw-black { font-weight: 900 !important; }
    .tracking-widest { letter-spacing: 0; }
    .transition-hover { transition: all 0.2s ease; }
    .transition-hover:hover { transform: translateY(-2px); }

    .metric-card, .panel-surface {
        background-color: #0f141e;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 1rem;
        box-shadow: 0 14px 30px rgba(0, 0, 0, 0.18);
        padding: 1.5rem;
    }

    .metric-card { border-left-width: 4px; }
    .metric-label { font-size: 0.72rem; font-weight: 800; letter-spacing: 0; text-transform: uppercase; margin-bottom: 0.35rem; }
    .icon-circle { width: 44px; height: 44px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; }

    .filter-control { width: auto; min-width: 150px; background-color: transparent; border-color: rgba(255,255,255,0.15); color: white; box-shadow: none; }
    .filter-control:focus, .filter-search .form-control:focus, .form-control:focus, .form-select:focus {
        background-color: rgba(255,255,255,0.05) !important;
        border-color: #00FFA3 !important;
        color: white !important;
        box-shadow: 0 0 0 0.25rem rgba(0, 255, 163, 0.18) !important;
    }
    .filter-search { width: 230px; }

    .modern-table { border-collapse: separate; border-spacing: 0; }
    .modern-row td {
        background-color: #111827;
        border-top: 1px solid rgba(255, 255, 255, 0.03);
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        transition: all 0.2s ease;
    }
    .modern-row td:first-child { border-left: 1px solid rgba(255, 255, 255, 0.03); }
    .modern-row td:last-child { border-right: 1px solid rgba(255, 255, 255, 0.03); }
    .modern-row:hover td { background-color: #172033; }
    .row-spacer td { height: 10px; padding: 0; background: transparent; border: none; }

    .btn-outline-info { color: #00B8D4; border-color: rgba(0, 184, 212, 0.5); }
    .btn-outline-info:hover { background-color: #00B8D4; color: #040508; border-color: #00B8D4; }

    .fade-in { animation: fadeIn 0.3s ease-in-out; }
    .slide-up { animation: slideUp 0.3s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private bool cargando = true;
    private bool guardando = false;
    private int usuarioId;
    private string nombreUsuario = "Usuario";
    private TurnoCaja? turnoActivo;
    private List<CategoriaEgreso> categorias = new();
    private List<Egreso> egresos = new();
    private Egreso nuevoEgreso = new();

    private DateTime fechaDesde = DateTime.Today.AddDays(-30);
    private DateTime fechaHasta = DateTime.Today;
    private int filtroCategoriaId = 0;
    private string filtroBusqueda = "";
    private string mensajeError = "";
    private string mensajeExito = "";

    private decimal TotalPeriodo => egresos.Sum(e => e.Monto);
    private decimal TotalHoy => egresos.Where(e => e.Fecha.Date == DateTime.Today).Sum(e => e.Monto);
    private decimal TotalTurnoActivo => turnoActivo == null ? 0 : egresos.Where(e => e.TurnoCajaId == turnoActivo.Id).Sum(e => e.Monto);

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarioActual();
        await CargarDatos();
    }

    private async Task CargarUsuarioActual()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        nombreUsuario = user.Identity?.Name ?? "Usuario";
        var claimId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(claimId, out var id))
        {
            usuarioId = id;
        }
    }

    private async Task CargarDatos()
    {
        cargando = true;
        mensajeError = "";

        categorias = await EgresoService.ObtenerCategoriasAsync();
        if (nuevoEgreso.CategoriaEgresoId == 0 && categorias.Any())
        {
            nuevoEgreso.CategoriaEgresoId = categorias.First().Id;
        }

        turnoActivo = usuarioId > 0 ? await CajaService.ObtenerTurnoActivoAsync(usuarioId) : null;

        int? categoria = filtroCategoriaId > 0 ? filtroCategoriaId : null;
        egresos = await EgresoService.ObtenerEgresosAsync(fechaDesde, fechaHasta, categoria, filtroBusqueda, 150);

        cargando = false;
    }

    private async Task RegistrarEgreso()
    {
        mensajeError = "";
        mensajeExito = "";

        if (turnoActivo == null)
        {
            mensajeError = "Debes abrir caja antes de registrar una salida de dinero.";
            return;
        }

        if (string.IsNullOrWhiteSpace(nuevoEgreso.Concepto))
        {
            mensajeError = "El concepto del egreso es obligatorio.";
            return;
        }

        guardando = true;

        try
        {
            nuevoEgreso.UsuarioId = usuarioId;
            nuevoEgreso.TurnoCajaId = turnoActivo.Id;

            await EgresoService.RegistrarEgresoAsync(nuevoEgreso);

            mensajeExito = "Egreso registrado y descontado del turno activo.";
            nuevoEgreso = new Egreso { CategoriaEgresoId = categorias.FirstOrDefault()?.Id ?? 0 };
            await CargarDatos();
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }
}
