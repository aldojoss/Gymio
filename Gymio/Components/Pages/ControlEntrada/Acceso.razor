@page "/acceso"
@attribute [Authorize]
@rendermode InteractiveServer
@using Gymio.Models
@using Gymio.Interfaces

@inject ISuscripcionService SuscripcionService
@inject IClienteService ClienteService
@inject IJSRuntime JS

<div class="page-container d-flex flex-column align-items-center justify-content-center min-vh-100 py-5 fade-in">
    
    @* ENCABEZADO TIPO TERMINAL *@
    <div class="text-center mb-5 slide-up">
        <h1 class="fw-black display-3 mb-0 text-white tracking-widest">GYM<span class="text-primary">IO</span></h1>
        <div class="d-inline-block mt-2 px-4 py-1 rounded-pill bg-primary bg-opacity-10 border border-primary border-opacity-25">
            <p class="text-primary fw-bold text-uppercase tracking-widest mb-0 small">
                <i class="bi bi-upc-scan me-2"></i>Terminal de Control
            </p>
        </div>
    </div>

    @* INPUT DEL ESCÁNER *@
    <div class="card scanner-box border-secondary border-opacity-25 rounded-4 mb-4 shadow-lg slide-up" style="max-width: 600px; width: 100%; background-color: rgba(15, 20, 30, 0.8); backdrop-filter: blur(10px);">
        <div class="card-body p-4 text-center position-relative overflow-hidden">
           
            @* linea láser decorativa animada *@
            <div class="laser-line"></div>

            <input type="text" @ref="inputScanner"
                   class="form-control form-control-lg bg-transparent border-0 text-center text-primary fw-black display-6 py-4 shadow-none scanner-input"
                   placeholder="PASE EL CARNET..."
                   @bind="codigoEscaneado" @bind:event="oninput" @onkeydown="ProcesarEscaneo" autofocus autocomplete="off" />
            
            <div class="mt-2 pulse-text small fw-bold text-muted tracking-widest">
                <i class="bi bi-shield-lock-fill me-1"></i> SISTEMA LISTO Y ESPERANDO ESCANEO
            </div>
        </div>
    </div>

    @* RESULTADO DEL ESCANEO *@
    <div style="min-height: 400px; max-width: 800px; width: 100%;">
        @if (busquedaRealizada)
        {
            <div class="card border-0 rounded-4 shadow-2xl overflow-hidden pop-in @(accesoPermitido ? "access-granted" : "access-denied")">
                <div class="row g-0">
                    
                    @* FOTO DEL SOCIO *@
                    <div class="col-md-4 d-flex align-items-center justify-content-center p-4 position-relative" style="background-color: rgba(0,0,0,0.2);">
                        @if (suscripcionActual?.Cliente != null && !string.IsNullOrEmpty(suscripcionActual.Cliente.FotoUrl))
                        {
                            <div class="photo-container @(accesoPermitido ? "border-success" : "border-danger")">
                                <img src="@suscripcionActual.Cliente.FotoUrl" class="img-fluid rounded-circle object-fit-cover shadow-lg" style="width: 180px; height: 180px;" />
                            </div>
                        }
                        else
                        {
                            <div class="photo-container @(accesoPermitido ? "border-success" : "border-danger") rounded-circle bg-dark d-flex align-items-center justify-content-center shadow-lg" style="width: 180px; height: 180px;">
                                <i class="bi bi-person-bounding-box display-1 text-muted opacity-50"></i>
                            </div>
                        }
                        
                        @* Icono flotante de estado *@
                        <div class="position-absolute bottom-0 end-0 mb-4 me-4 bg-dark rounded-circle p-2 shadow-lg border @(accesoPermitido ? "border-success text-success" : "border-danger text-danger")" style="transform: translate(-20px, -20px);">
                            <i class="bi @(accesoPermitido ? "bi-check-circle-fill" : "bi-x-circle-fill") fs-3"></i>
                        </div>
                    </div>
                    
                    @* DATOS DEL ACCESO *@
                    <div class="col-md-8 p-5 d-flex flex-column justify-content-center">
                        <div class="mb-2 text-uppercase fw-black tracking-widest @(accesoPermitido ? "text-success" : "text-danger")" style="font-size: 0.9rem;">
                            @(accesoPermitido ? "● ACCESO AUTORIZADO" : "● ACCESO DENEGADO")
                        </div>
                        
                        <h1 class="fw-black text-white mb-1 display-5 text-truncate">
                            @(suscripcionActual?.Cliente?.Nombre ?? "---") @(suscripcionActual?.Cliente?.Apellido ?? "")
                        </h1>
                        <p class="text-muted mb-4 fw-medium font-monospace tracking-widest">
                            ID SOCIO: #@(suscripcionActual?.Cliente?.Id.ToString("D4") ?? "0000")
                        </p>

                        <div class="row g-3">
                            <div class="col-6">
                                <div class="p-3 rounded-4 info-box h-100">
                                    <div class="text-muted small fw-bold mb-1 tracking-widest">MEMBRESÍA</div>
                                    <div class="fw-bold text-white fs-5">@(suscripcionActual?.Plan?.Nombre ?? "SIN PLAN")</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 rounded-4 info-box h-100">
                                    <div class="text-muted small fw-bold mb-1 tracking-widest">VENCIMIENTO</div>
                                    <div class="fw-bold fs-5 @(accesoPermitido ? "text-info" : "text-danger")">
                                        @(suscripcionActual?.FechaVencimiento.ToShortDateString() ?? "---")
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 mt-3">
                                <div class="alert @(accesoPermitido ? "alert-success border-success" : "alert-danger border-danger") bg-opacity-10 border border-opacity-25 fw-bold mb-0 text-center tracking-widest text-uppercase">
                                    @if(accesoPermitido) { <i class="bi bi-unlock-fill me-2"></i> } else { <i class="bi bi-lock-fill me-2"></i> }
                                    @mensajeSistema
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Bases y utilidades */
    .page-container { font-family: 'Segoe UI', Roboto, sans-serif; }
    .fw-black { font-weight: 900 !important; }
    .tracking-widest { letter-spacing: 0.15em; }
    .text-primary { color: #00FFA3 !important; }
    
    /* El input del escáner invisible pero activo */
    .scanner-box { border-top: 3px solid #00FFA3; transition: all 0.3s ease; }
    .scanner-box:focus-within { box-shadow: 0 0 30px rgba(0, 255, 163, 0.2) !important; border-color: #00FFA3 !important; }
    .scanner-input::placeholder { color: rgba(0, 255, 163, 0.3); letter-spacing: 5px; }
    .scanner-input:focus { color: #00FFA3 !important; outline: none; box-shadow: none; }

    /* Tarjetas de resultado con neón */
    .access-granted { 
        background: linear-gradient(135deg, rgba(0, 255, 163, 0.15), rgba(0, 184, 212, 0.05)); 
        border: 1px solid rgba(0, 255, 163, 0.3) !important; 
        box-shadow: 0 10px 40px rgba(0, 255, 163, 0.15); 
        backdrop-filter: blur(10px);
    }
    .access-denied { 
        background: linear-gradient(135deg, rgba(244, 63, 94, 0.15), rgba(0, 0, 0, 0.2)); 
        border: 1px solid rgba(244, 63, 94, 0.3) !important; 
        box-shadow: 0 10px 40px rgba(244, 63, 94, 0.15); 
        backdrop-filter: blur(10px);
    }

    /* Foto del socio */
    .photo-container { border: 4px solid; padding: 5px; background: rgba(0,0,0,0.3); }

    /* Cajas interiores de la tarjeta */
    .info-box { background-color: rgba(0, 0, 0, 0.2); border: 1px solid rgba(255, 255, 255, 0.05); }

    /* Animaciones */
    .fade-in { animation: fadeIn 0.5s ease-in-out; }
    .slide-up { animation: slideUp 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .pop-in { animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .pulse-text { animation: blink 2s infinite; }
    
    .laser-line {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: #00FFA3;
        box-shadow: 0 0 10px #00FFA3;
        opacity: 0.5;
        animation: scan 2.5s infinite linear;
        pointer-events: none;
    }

    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes popIn { 0% { opacity: 0; transform: scale(0.95); } 100% { opacity: 1; transform: scale(1); } }
    @@keyframes blink { 0% { opacity: 0.4; } 50% { opacity: 1; } 100% { opacity: 0.4; } }
    @@keyframes scan { 0% { top: 0; opacity: 0; } 10% { opacity: 0.5; } 50% { top: 100%; opacity: 0.5; } 60% { opacity: 0; top: 100%; } 100% { top: 0; opacity: 0; } }
</style>

@code {
    private ElementReference inputScanner;
    private string codigoEscaneado = "";
    private bool busquedaRealizada = false;
    private bool accesoPermitido = false;
    private string mensajeSistema = "";
    private SuscripcionCliente? suscripcionActual;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) 
        { 
            try 
            {
                await inputScanner.FocusAsync();
            }
            catch {}
        }
    }

    private async Task ProcesarEscaneo(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(codigoEscaneado))
        {
            // se valida el acceso, con el codigo , qr 
            var res = await SuscripcionService.ValidarAccesoConQrAsync(codigoEscaneado.Trim());
            accesoPermitido = res.Permitido;
            mensajeSistema = res.Mensaje;
            suscripcionActual = res.Suscripcion;
            busquedaRealizada = true;

            if (suscripcionActual?.Cliente != null)
            {
                await ClienteService.RegistrarAsistenciaAsync(suscripcionActual.Cliente.Id, accesoPermitido);
            }

            codigoEscaneado = "";
            StateHasChanged();

            // Limpiar la pantalla tras 6 segundos para el siguiente
            await Task.Delay(6000);
            
            busquedaRealizada = false;
            StateHasChanged();
            
            try
            {
                await Task.Delay(100);
                await inputScanner.FocusAsync();
            }
            catch
            {
            }
        }
    }
}