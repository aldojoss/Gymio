@page "/acceso"
@attribute [Authorize]
@rendermode InteractiveServer
@using Gymio.Models
@using Gymio.Interfaces

@inject ISuscripcionService SuscripcionService
@inject IClienteService ClienteService
@inject IJSRuntime JS

<div class="container-fluid min-vh-100 d-flex flex-column align-items-center justify-content-center bg-dark text-white py-5">
    
    <div class="text-center mb-5">
        <h1 class="fw-black display-3 mb-0" style="letter-spacing: -2px;">GYM<span class="text-primary">IO</span></h1>
        <p class="text-white-50 fw-bold text-uppercase" style="letter-spacing: 4px;">Control de Puerta</p>
    </div>

    <div class="card bg-secondary bg-opacity-10 border-0 rounded-4 mb-4 shadow-lg" style="max-width: 500px; width: 100%;">
        <div class="card-body p-4 text-center">
            <input type="text" @ref="inputScanner"
                   class="form-control form-control-lg bg-dark border-secondary border-opacity-25 text-center text-primary fw-black fs-2 py-3 shadow-none"
                   placeholder="PASE EL CARNET..."
                   @bind="codigoEscaneado" @bind:event="oninput" @onkeydown="ProcesarEscaneo" autofocus />
            <div class="mt-3 pulse-text small fw-bold text-white-50">SISTEMA LISTO PARA ESCANEAR</div>
        </div>
    </div>

    <div style="min-height: 400px; max-width: 800px; width: 100%;">
        @if (busquedaRealizada)
        {
            <div class="card border-0 rounded-5 shadow-2xl overflow-hidden fade-in @(accesoPermitido ? "bg-success" : "bg-danger") bg-opacity-10">
                <div class="row g-0">
                    <div class="col-md-4 d-flex align-items-center justify-content-center p-4 bg-dark bg-opacity-25">
                        @if (suscripcionActual?.Cliente != null && !string.IsNullOrEmpty(suscripcionActual.Cliente.FotoUrl))
                        {
                            <img src="@suscripcionActual.Cliente.FotoUrl" class="img-fluid rounded-4 shadow-sm" style="width: 100%; aspect-ratio: 1/1; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-dark rounded-4 d-flex align-items-center justify-content-center" style="width: 100%; aspect-ratio: 1/1;">
                                <span class="display-1">👤</span>
                            </div>
                        }
                    </div>
                    <div class="col-md-8 p-5 d-flex flex-column justify-content-center">
                        <div class="mb-1 text-uppercase fw-black small @(accesoPermitido ? "text-success" : "text-danger")" style="letter-spacing: 2px;">
                            @(accesoPermitido ? "Acceso Autorizado" : "Acceso Denegado")
                        </div>
                        <h1 class="fw-black mb-1">@(suscripcionActual?.Cliente?.Nombre ?? "---") @(suscripcionActual?.Cliente?.Apellido ?? "")</h1>
                        <p class="text-white-50 mb-4 fw-medium">ID Socio: @(suscripcionActual?.Cliente?.Id.ToString("D4") ?? "0000")</p>

                        <div class="row g-3">
                            <div class="col-6">
                                <div class="bg-dark bg-opacity-50 p-3 rounded-4 border border-white border-opacity-10">
                                    <div class="text-white-50 small fw-bold mb-1">MEMBRESÍA</div>
                                    <div class="fw-bold">@(suscripcionActual?.Plan?.Nombre ?? "SIN PLAN")</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-dark bg-opacity-50 p-3 rounded-4 border border-white border-opacity-10">
                                    <div class="text-white-50 small fw-bold mb-1">VENCIMIENTO</div>
                                    <div class="fw-bold @(accesoPermitido ? "text-white" : "text-danger")">
                                        @(suscripcionActual?.FechaVencimiento.ToLongDateString() ?? "---")
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 mt-3">
                                <div class="alert @(accesoPermitido ? "alert-success" : "alert-danger") bg-opacity-10 border-0 fw-bold mb-0">
                                    📢 @mensajeSistema
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .fw-black { font-weight: 900 !important; }
    .fade-in { animation: slideUp 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .pulse-text { animation: blink 1.5s infinite; }
    
    /* agregamos doble @@ para que el compilador de Blazor no de error */
    @@keyframes slideUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes blink { 0% { opacity: 0.3; } 50% { opacity: 1; } 100% { opacity: 0.3; } }
</style>

@code {
    private ElementReference inputScanner;
    private string codigoEscaneado = "";
    private bool busquedaRealizada = false;
    private bool accesoPermitido = false;
    private string mensajeSistema = "";
    private SuscripcionCliente? suscripcionActual;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await inputScanner.FocusAsync(); }
    }

    private async Task ProcesarEscaneo(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(codigoEscaneado))
        {
            // Ejecutar validación
            var res = await SuscripcionService.ValidarAccesoConQrAsync(codigoEscaneado.Trim());
            
            accesoPermitido = res.Permitido;
            mensajeSistema = res.Mensaje;
            suscripcionActual = res.Suscripcion;
            busquedaRealizada = true;

            // Registrar asistencia en tu tabla histórica usando tu servicio original
            if (suscripcionActual?.Cliente != null)
            {
                await ClienteService.RegistrarAsistenciaAsync(suscripcionActual.Cliente.Id, accesoPermitido);
            }

            codigoEscaneado = "";
            StateHasChanged();

            // Limpiar la pantalla tras 6 segundos para el siguiente
            await Task.Delay(6000);
            busquedaRealizada = false;
            StateHasChanged();
            await inputScanner.FocusAsync();
        }
    }
}