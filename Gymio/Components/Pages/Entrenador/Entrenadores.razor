    private async Task GuardarEntrenador()
    {
        mensajeErrorModal = "";

        if (!string.IsNullOrWhiteSpace(nuevoCoach.NombreCompleto) && 
            !string.IsNullOrWhiteSpace(nuevoCoach.Email) && 
            !string.IsNullOrWhiteSpace(passwordPlano))
        {
            bool exito = await AuthService.CrearUsuarioFuerteAsync(nuevoCoach, passwordPlano);
            if (exito)
            {
                 if (fotoCoach != null)
                 {
                     try
                     {
                         nuevoCoach.FotoUrl = await ProfileImageService.GuardarImagenPerfilAsync(fotoCoach, "staff", nuevoCoach.FotoUrl);
                         await AuthService.ActualizarFotoUsuarioAsync(nuevoCoach.Id, nuevoCoach.FotoUrl);
                     }
                     catch (Exception ex)
                     {
                         mensajeErrorModal = ex.Message;
                         return;
                     }
                 }

                 mostrarModalNuevo = false;
                 await CargarEntrenadores();
                 
          
                 await MostrarExitoTemporal($"El coach {nuevoCoach.NombreCompleto} ha sido registrado en el sistema.");
                 
                 nuevoCoach = new Usuario();
                 passwordPlano = "";
                 fotoCoach = null;
                 fotoCoachPreviewUrl = null;
                 nombreFotoCoach = null;
            }
            else 
            {
                 mensajeErrorModal = "Este correo ya está registrado en el sistema. Debe ser único.";
            }
        }
        else
        {
            mensajeErrorModal = "Por favor, completá todos los campos requeridos.";
        }
    }

