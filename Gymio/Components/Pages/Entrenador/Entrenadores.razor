    @* ---modal*@
    private async Task AbrirModalPago(Usuario coach)
    {
        coachSeleccionado = coach;
        montoPagar = 0;
        mensajeErrorPago = "";
        mostrarModalPago = true;

        var ultimoFin = await PlanillaService.ObtenerUltimaFechaPagoAsync(coach.Id);
        if (ultimoFin.HasValue)
        {
            fechaInicio = ultimoFin.Value.AddDays(1);
            fechaFin = fechaInicio.AddDays(14);
        }
        else
        {
            fechaInicio = DateTime.Today;
            fechaFin = DateTime.Today.AddDays(15);
        }
    }

    private void CerrarModalPago() => mostrarModalPago = false;

    private async Task ProcesarPago()
    {
       mensajeErrorPago = "";

        if (montoPagar <= 0)
        {
            mensajeErrorPago = "El monto a pagar debe ser mayor a 0 C$.";
            return;
        }

        if (coachSeleccionado != null)
        {
            bool exito = await PlanillaService.RegistrarPagoAsync(
                coachSeleccionado.Id, 
                idCajeroActual, 
                montoPagar, 
                fechaInicio, 
                fechaFin);

            if (exito)
            {
                mostrarModalPago = false;
                
              
                await MostrarExitoTemporal($"Se ha registrado correctamente el pago de C$ {montoPagar:N2} a {coachSeleccionado.NombreCompleto}.");
            }
            else
            {
                mensajeErrorPago = "Error al procesar: Este periodo entra en conflicto o se solapa con un pago anterior.";
            }
        }
    }
