        mostrarModalEdicion = true;
    }

    private void CerrarModalEdicion()
    {
        mostrarModalEdicion = false;
        passwordEdicion = "";
        mensajeErrorEdicion = "";
        fotoCoachEdicion = null;
        fotoCoachEdicionPreviewUrl = null;
        nombreFotoCoachEdicion = null;
    }

    private async Task GuardarEdicionEntrenador()
    {
        mensajeErrorEdicion = "";

        if (string.IsNullOrWhiteSpace(coachEdicion.NombreCompleto) || string.IsNullOrWhiteSpace(coachEdicion.Email))
        {
            mensajeErrorEdicion = "El nombre y el correo son obligatorios.";
            return;
        }

        var correoLimpio = coachEdicion.Email.Trim().ToLower();

        using var context = await DbFactory.CreateDbContextAsync();
        var existeUsuario = await context.Usuarios.AnyAsync(u => u.Email != null && u.Email.Trim().ToLower() == correoLimpio && u.Id != coachEdicion.Id);
        var existeCliente = await context.Clientes.AnyAsync(c => c.Email != null && c.Email.Trim().ToLower() == correoLimpio);

        if (existeUsuario || existeCliente)
        {
            mensajeErrorEdicion = "Este correo ya está registrado en el sistema.";
            return;
        }

        var coachDb = await context.Usuarios.FindAsync(coachEdicion.Id);
        if (coachDb == null)
        {
            mensajeErrorEdicion = "No se encontró el coach seleccionado.";
            return;
        }

        try
        {
            coachDb.NombreCompleto = coachEdicion.NombreCompleto.Trim();
            coachDb.Email = correoLimpio;
            coachDb.Rol = "Entrenador";
            coachDb.Activo = coachEdicion.Activo;

            if (!string.IsNullOrWhiteSpace(passwordEdicion))
            {
                coachDb.PasswordHash = BCrypt.Net.BCrypt.HashPassword(passwordEdicion);
            }

            if (fotoCoachEdicion != null)
            {
                coachDb.FotoUrl = await ProfileImageService.GuardarImagenPerfilAsync(fotoCoachEdicion, "staff", coachDb.FotoUrl);
            }

            await context.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            mensajeErrorEdicion = ex.Message;
            return;
        }

        CerrarModalEdicion();
        await CargarEntrenadores();
        await MostrarExitoTemporal($"El coach {coachDb.NombreCompleto} fue actualizado correctamente.");
    }

