@code {
    private List<Cliente> misClientes = new();
    private Cliente? clienteSeleccionado;
    private bool cargandoClientes = true;
    private string tabActual = "rutina";
    private int idEntrenadorActual;

    private Rutina rutinaActual = new();
    private string diaSeleccionado = "";
    private string nuevoDiaNombre = "";
    private bool guardandoRutina;
    private string mensajeRutina = "";

    private List<EjercicioCatalogo> catalogo = new();
    private List<string> gruposMusculares = new();
    private List<string> equipos = new();
    private string filtroCatalogo = "";
    private string grupoFiltro = "";
    private string equipoFiltro = "";
    private bool catalogoCargando;
    private EjercicioCatalogo? ejercicioSeleccionado;
    private bool mostrarModalEjercicio;
    private EjercicioCatalogo nuevoEjercicioCatalogo = new();
    private string errorCatalogo = "";

    private int seriesInput = 3;
    private string repsInput = "8-12";
    private int descansoInput = 90;
    private string rirInput = "2 RIR";
    private string notasCoachInput = "";

    private List<RegistroEntrenamiento> historialEntrenamientos = new();
    private ChatEntrenador chatActual = new();
    private string nuevoMensajeTexto = "";
    private HubConnection? hubConnection;

    private string UltimaSesionTexto => historialEntrenamientos.FirstOrDefault()?.FechaEntrenamiento.ToString("dd/MM") ?? "Sin datos";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is not null && user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
            if (userIdClaim != null)
            {
                idEntrenadorActual = int.Parse(userIdClaim.Value);
            }
        }

        await CargarCatalogoInicial();
        misClientes = await ClienteService.ObtenerClientesPorEntrenadorAsync(idEntrenadorActual);
        cargandoClientes = false;

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/chathub"))
            .Build();

        hubConnection.On<string>("ChatActualizado", async chatId =>
        {
            if (clienteSeleccionado != null && chatActual.Id == chatId)
            {
                chatActual = await ChatService.ObtenerOCrearChatAsync(clienteSeleccionado.Id, idEntrenadorActual);
                await InvokeAsync(StateHasChanged);
            }
        });

        await hubConnection.StartAsync();
    }

    private async Task CargarCatalogoInicial()
    {
        gruposMusculares = (await EjercicioCatalogoService.ObtenerGruposMuscularesAsync()).OrderBy(g => g).ToList();
        equipos = (await EjercicioCatalogoService.ObtenerEquiposAsync()).OrderBy(e => e).ToList();
        await CargarCatalogo();
    }

    private async Task CargarCatalogo()
    {
        catalogoCargando = true;
        catalogo = await EjercicioCatalogoService.BuscarEjerciciosAsync(filtroCatalogo, grupoFiltro, equipoFiltro);
        ejercicioSeleccionado ??= catalogo.FirstOrDefault();
        catalogoCargando = false;
    }

    private async Task BuscarCatalogo()
    {
        await CargarCatalogo();
    }

    private async Task SeleccionarCliente(Cliente cliente)
    {
        clienteSeleccionado = cliente;
        chatActual = await ChatService.ObtenerOCrearChatAsync(cliente.Id, idEntrenadorActual);
        historialEntrenamientos = await RegistroEntrenamientoService.ObtenerPorClienteAsync(cliente.Id, 12);

        var rutinaDb = await RutinaService.ObtenerRutinaActivaAsync(cliente.Id);
        rutinaActual = rutinaDb ?? CrearRutinaBase(cliente.Id);
        await HidratarRutinaConCatalogoAsync(rutinaActual);
        AsegurarDiaInicial();
        tabActual = "rutina";
    }

    private Rutina CrearRutinaBase(int clienteId)
    {
        return new Rutina
        {
            ClienteId = clienteId,
            EntrenadorId = idEntrenadorActual,
            Titulo = "Plan de entrenamiento",
            Objetivo = "Hipertrofia",
            IndicacionesGenerales = "Calienta 8-10 minutos, registra tus cargas y conserva tecnica limpia.",
            FechaInicio = DateTime.Today,
            FechaFin = DateTime.Today.AddDays(56),
            Activa = true,
            Dias = new List<DiaEntrenamiento>
            {
                new() { OrdenDia = 1, NombreDia = "Dia 1 - Full body", FocoMuscular = "General" }
            }
        };
    }

    private void NuevaRutina()
    {
        if (clienteSeleccionado == null) return;
        rutinaActual = CrearRutinaBase(clienteSeleccionado.Id);
        AsegurarDiaInicial();
        mensajeRutina = "";
    }

    private void AsegurarDiaInicial()
    {
        if (!rutinaActual.Dias.Any())
        {
            rutinaActual.Dias.Add(new DiaEntrenamiento { OrdenDia = 1, NombreDia = "Dia 1 - Full body", FocoMuscular = "General" });
        }

        diaSeleccionado = rutinaActual.Dias.OrderBy(d => d.OrdenDia).First().NombreDia;
    }

    private async Task HidratarRutinaConCatalogoAsync(Rutina rutina)
    {
        foreach (var ejercicio in rutina.Dias.SelectMany(d => d.Ejercicios))
        {
            var necesitaVisual = string.IsNullOrWhiteSpace(ejercicio.GifUrl);
            var necesitaTecnica = string.IsNullOrWhiteSpace(ejercicio.InstruccionesTecnicas);

            if (!necesitaVisual && !necesitaTecnica)
            {
                continue;
            }

            EjercicioCatalogo? catalogo = null;

            if (!string.IsNullOrWhiteSpace(ejercicio.EjercicioCatalogoId))
            {
                catalogo = await EjercicioCatalogoService.ObtenerPorIdAsync(ejercicio.EjercicioCatalogoId);
            }

            if (catalogo == null || string.IsNullOrWhiteSpace(catalogo.GifUrl))
            {
                catalogo = await EjercicioCatalogoService.ResolverVisualPorNombreAsync(ejercicio.NombreEjercicio);
            }

            if (catalogo == null)
            {
                continue;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.GifUrl))
            {
                ejercicio.GifUrl = catalogo.GifUrl;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.InstruccionesTecnicas))
            {
                ejercicio.InstruccionesTecnicas = catalogo.Instrucciones;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.ErroresComunes))
            {
                ejercicio.ErroresComunes = catalogo.ErroresComunes;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.GrupoMuscularPrincipal))
            {
                ejercicio.GrupoMuscularPrincipal = catalogo.GrupoMuscularPrincipal;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.Equipo))
            {
                ejercicio.Equipo = catalogo.Equipo;
            }
        }
    }

    private void SeleccionarEjercicio(EjercicioCatalogo ejercicio)
    {
        ejercicioSeleccionado = ejercicio;
        notasCoachInput = "";
    }

    private void SeleccionarDia(string nombreDia)
    {
        diaSeleccionado = nombreDia;
    }

    private void AgregarDia()
    {
        var nombre = nuevoDiaNombre.Trim();
        if (string.IsNullOrWhiteSpace(nombre) || rutinaActual.Dias.Any(d => d.NombreDia.Equals(nombre, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        rutinaActual.Dias.Add(new DiaEntrenamiento
        {
            NombreDia = nombre,
            FocoMuscular = nombre,
            OrdenDia = rutinaActual.Dias.Count + 1
        });

        diaSeleccionado = nombre;
        nuevoDiaNombre = "";
    }

    private void AgregarEjercicioDesdeCatalogo()
    {
        if (ejercicioSeleccionado == null || string.IsNullOrWhiteSpace(diaSeleccionado))
        {
            return;
        }

        var dia = rutinaActual.Dias.FirstOrDefault(d => d.NombreDia == diaSeleccionado);
        if (dia == null)
        {
            return;
        }

        dia.Ejercicios.Add(new EjercicioRutina
        {
            EjercicioCatalogoId = ejercicioSeleccionado.Id,
            NombreEjercicio = ejercicioSeleccionado.Nombre,
            GrupoMuscularPrincipal = ejercicioSeleccionado.GrupoMuscularPrincipal,
            Equipo = ejercicioSeleccionado.Equipo,
            Nivel = ejercicioSeleccionado.Nivel,
            InstruccionesTecnicas = ejercicioSeleccionado.Instrucciones,
            ErroresComunes = ejercicioSeleccionado.ErroresComunes,
            GifUrl = ejercicioSeleccionado.GifUrl,
            UrlVideoReferencia = ejercicioSeleccionado.VideoUrl,
            Series = Math.Max(1, seriesInput),
            Repeticiones = repsInput,
            DescansoSegundos = descansoInput,
            RIR = rirInput,
            NotasCoach = notasCoachInput,
            Orden = dia.Ejercicios.Count + 1
        });

        notasCoachInput = "";
    }

    private async Task GuardarRutinaEnBD()
    {
        if (clienteSeleccionado == null) return;

        guardandoRutina = true;
        mensajeRutina = "";

        rutinaActual.ClienteId = clienteSeleccionado.Id;
        rutinaActual.EntrenadorId = idEntrenadorActual;
        rutinaActual.Activa = true;

        if (rutinaActual.FechaInicio == default)
        {
            rutinaActual.FechaInicio = DateTime.Today;
        }

        if (rutinaActual.FechaFin == default)
        {
            rutinaActual.FechaFin = rutinaActual.FechaInicio.AddDays(56);
        }

        await HidratarRutinaConCatalogoAsync(rutinaActual);

        if (string.IsNullOrWhiteSpace(rutinaActual.Id))
        {
            await RutinaService.CrearRutinaAsync(rutinaActual);
        }
        else
        {
            await RutinaService.ActualizarRutinaAsync(rutinaActual);
        }

        mensajeRutina = "Rutina guardada y activa para el atleta.";
        guardandoRutina = false;
    }

    private void EliminarEjercicio(DiaEntrenamiento dia, EjercicioRutina ejercicio)
    {
        dia.Ejercicios.Remove(ejercicio);
        var orden = 1;
        foreach (var item in dia.Ejercicios)
        {
            item.Orden = orden++;
        }
    }

    private void AbrirModalEjercicio()
    {
        nuevoEjercicioCatalogo = new EjercicioCatalogo { Nivel = "Principiante", Activo = true };
        errorCatalogo = "";
        mostrarModalEjercicio = true;
    }

    private void CerrarModalEjercicio()
    {
        mostrarModalEjercicio = false;
    }

    private async Task GuardarEjercicioCatalogo()
    {
        errorCatalogo = "";

        if (string.IsNullOrWhiteSpace(nuevoEjercicioCatalogo.Nombre) ||
            string.IsNullOrWhiteSpace(nuevoEjercicioCatalogo.GrupoMuscularPrincipal) ||
            string.IsNullOrWhiteSpace(nuevoEjercicioCatalogo.Equipo))
        {
            errorCatalogo = "Nombre, musculo principal y equipo son obligatorios.";
            return;
        }

        ejercicioSeleccionado = await EjercicioCatalogoService.CrearEjercicioAsync(nuevoEjercicioCatalogo);
        mostrarModalEjercicio = false;
        await CargarCatalogoInicial();
    }

    private async Task AbrirChat()
    {
        tabActual = "chat";
        if (!string.IsNullOrWhiteSpace(chatActual.Id))
        {
            await ChatService.MarcarMensajesComoLeidosAsync(chatActual.Id, "Entrenador");
        }
    }

    private async Task ManejarEnterChat(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await EnviarMensaje();
        }
    }

    private async Task EnviarMensaje()
    {
        if (string.IsNullOrWhiteSpace(nuevoMensajeTexto) || string.IsNullOrWhiteSpace(chatActual.Id))
        {
            return;
        }

        var msg = new Mensaje { Texto = nuevoMensajeTexto.Trim(), RolRemitente = "Entrenador", RemitenteId = idEntrenadorActual };
        await ChatService.EnviarMensajeAsync(chatActual.Id, msg);

        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
        {
            await hubConnection.SendAsync("NotificarNuevoMensaje", chatActual.Id);
        }

        chatActual.Historial.Add(msg);
        nuevoMensajeTexto = "";
    }

    private static string Iniciales(Cliente cliente)
    {
        var nombre = string.IsNullOrWhiteSpace(cliente.Nombre) ? "A" : cliente.Nombre[..1];
        var apellido = string.IsNullOrWhiteSpace(cliente.Apellido) ? "" : cliente.Apellido[..1];
        return $"{nombre}{apellido}".ToUpper();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
