@page "/portal-entrenador"
@attribute [Authorize(Roles = "Entrenador, Administrador")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable

@using Gymio.Models
@using Gymio.Interfaces
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IChatService ChatService
@inject IClienteService ClienteService
@inject IRutinaService RutinaService
@inject IEjercicioCatalogoService EjercicioCatalogoService
@inject IRegistroEntrenamientoService RegistroEntrenamientoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Portal Entrenador - Gymio</PageTitle>

<div class="coach-shell text-light">
    <aside class="coach-sidebar">
        <div class="sidebar-header">
            <div>
                <h5 class="fw-black text-primary mb-0"><i class="bi bi-lightning-charge-fill me-2"></i>Mis Atletas</h5>
                <span class="text-muted small">Clientes asignados</span>
            </div>
            <span class="badge bg-primary text-dark rounded-pill">@misClientes.Count</span>
        </div>

        <div class="client-list custom-scrollbar">
            @if (cargandoClientes)
            {
                <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
            }
            else if (!misClientes.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-person-slash display-6 text-white-50"></i>
                    <h6 class="text-white fw-bold mt-3">Sin atletas</h6>
                    <p class="text-muted small mb-0">Aún no tienes socios asignados.</p>
                </div>
            }
            else
            {
                @foreach (var cliente in misClientes)
                {
                    var activo = clienteSeleccionado?.Id == cliente.Id;
                    <button class="client-card @(activo ? "active" : "")" @onclick="() => SeleccionarCliente(cliente)">
                        <span class="client-avatar">@Iniciales(cliente)</span>
                        <span class="flex-grow-1 text-start">
                            <span class="client-name">@cliente.Nombre @cliente.Apellido</span>
                            <span class="client-code"><i class="bi bi-upc-scan me-1"></i>@cliente.CodigoQR</span>
                        </span>
                        @if (activo)
                        {
                            <i class="bi bi-chevron-right text-primary"></i>
                        }
                    </button>
                }
            }
        </div>
    </aside>

    <main class="coach-workspace">
        @if (clienteSeleccionado == null)
        {
            <div class="empty-workspace">
                <div class="empty-orbit">
                    <i class="bi bi-person-bounding-box display-2 text-primary"></i>
                </div>
                <h2 class="text-white fw-black mb-2">Selecciona un atleta</h2>
                <p class="text-muted mb-0">Desde aquí armas rutinas, revisas progreso y mantienes el chat activo.</p>
            </div>
        }
        else
        {
            <header class="workspace-header">
                <div class="d-flex align-items-center gap-3">
                    <span class="header-avatar">@Iniciales(clienteSeleccionado)</span>
                    <div>
                        <h2 class="text-white fw-black mb-1">@clienteSeleccionado.Nombre @clienteSeleccionado.Apellido</h2>
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">
                            <i class="bi bi-circle-fill me-2" style="font-size: 0.45rem;"></i>Coaching activo
                        </span>
                    </div>
                </div>

                <div class="segmented-tabs">
                    <button class="tab-btn @(tabActual == "rutina" ? "active" : "")" @onclick='() => tabActual = "rutina"'><i class="bi bi-clipboard2-pulse me-2"></i>Rutina</button>
                    <button class="tab-btn @(tabActual == "progreso" ? "active" : "")" @onclick='() => tabActual = "progreso"'><i class="bi bi-graph-up-arrow me-2"></i>Progreso</button>
                    <button class="tab-btn @(tabActual == "chat" ? "active" : "")" @onclick="AbrirChat"><i class="bi bi-chat-dots me-2"></i>Chat</button>
                </div>
            </header>

            <section class="workspace-body custom-scrollbar">
                @if (tabActual == "rutina")
                {
                    <div class="routine-grid">
                        <div class="panel routine-meta">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
                                <div>
                                    <h5 class="text-white fw-black mb-1">Plan activo</h5>
                                    <span class="text-muted small">Define el objetivo y las indicaciones generales.</span>
                                </div>
                                <button class="btn btn-outline-info rounded-pill fw-bold px-3" @onclick="NuevaRutina">
                                    <i class="bi bi-plus-lg me-2"></i>Nueva
                                </button>
                            </div>

                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">Nombre del plan</label>
                                    <input class="form-control control-dark" @bind="rutinaActual.Titulo" placeholder="Ej: Hipertrofia tren superior" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Objetivo</label>
                                    <select class="form-select control-dark" @bind="rutinaActual.Objetivo">
                                        <option value="Hipertrofia">Hipertrofia</option>
                                        <option value="Fuerza">Fuerza</option>
                                        <option value="Resistencia">Resistencia</option>
                                        <option value="Recomposicion">Recomposicion</option>
                                        <option value="Movilidad">Movilidad</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Inicio</label>
                                    <input type="date" class="form-control control-dark" @bind="rutinaActual.FechaInicio" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Fin</label>
                                    <input type="date" class="form-control control-dark" @bind="rutinaActual.FechaFin" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Indicaciones generales</label>
                                    <textarea class="form-control control-dark" rows="2" @bind="rutinaActual.IndicacionesGenerales" placeholder="Calentamiento, movilidad, cardio, progresion de cargas..."></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="panel catalog-panel">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h5 class="text-white fw-black mb-1">Catalogo de ejercicios</h5>
                                    <span class="text-muted small">Busca por musculo, equipo o nombre.</span>
                                </div>
                                <button class="btn btn-gradient rounded-pill px-3 fw-bold" @onclick="AbrirModalEjercicio">
                                    <i class="bi bi-plus-lg me-2"></i>Crear
                                </button>
                            </div>

                            <div class="row g-2 mb-3">
                                <div class="col-12">
                                    <div class="input-group">
                                        <span class="input-group-text bg-transparent border-secondary border-opacity-25 text-muted"><i class="bi bi-search"></i></span>
                                        <input class="form-control control-dark" placeholder="Buscar ejercicio..." @bind="filtroCatalogo" @bind:event="oninput" @onkeyup="BuscarCatalogo" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <select class="form-select control-dark" @bind="grupoFiltro" @bind:after="CargarCatalogo">
                                        <option value="">Todos los musculos</option>
                                        @foreach (var grupo in gruposMusculares)
                                        {
                                            <option value="@grupo">@grupo</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <select class="form-select control-dark" @bind="equipoFiltro" @bind:after="CargarCatalogo">
                                        <option value="">Todo equipo</option>
                                        @foreach (var equipo in equipos)
                                        {
                                            <option value="@equipo">@equipo</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="catalog-list custom-scrollbar">
                                @if (catalogoCargando)
                                {
                                    <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
                                }
                                else if (!catalogo.Any())
                                {
                                    <div class="empty-state compact">
                                        <i class="bi bi-search text-white-50 fs-2"></i>
                                        <p class="text-muted small mb-0 mt-2">No hay ejercicios con esos filtros.</p>
                                    </div>
                                }
                                else
                                {
                                    @foreach (var ejercicio in catalogo)
                                    {
                                        var activo = ejercicioSeleccionado?.Id == ejercicio.Id;
                                        <button class="exercise-option @(activo ? "active" : "")" @onclick="() => SeleccionarEjercicio(ejercicio)">
                                            <span class="exercise-icon"><i class="bi bi-person-arms-up"></i></span>
                                            <span class="flex-grow-1 text-start">
                                                <span class="text-white fw-bold d-block">@ejercicio.Nombre</span>
                                                <span class="text-muted small">@ejercicio.GrupoMuscularPrincipal · @ejercicio.Equipo</span>
                                            </span>
                                        </button>
                                    }
                                }
                            </div>
                        </div>

                        <div class="panel exercise-preview">
                            @if (ejercicioSeleccionado == null)
                            {
                                <div class="empty-state h-100">
                                    <i class="bi bi-play-circle display-5 text-primary"></i>
                                    <h6 class="text-white fw-bold mt-3">Elige un ejercicio</h6>
                                    <p class="text-muted small mb-0">Veras instrucciones, errores comunes y opciones para asignarlo.</p>
                                </div>
                            }
                            else
                            {
                                <div class="exercise-media mb-3">
                                    @if (!string.IsNullOrWhiteSpace(ejercicioSeleccionado.GifUrl))
                                    {
                                        <img src="@ejercicioSeleccionado.GifUrl" alt="@ejercicioSeleccionado.Nombre" loading="lazy" referrerpolicy="no-referrer" />
                                    }
                                    else
                                    {
                                        <div class="media-placeholder">
                                            <i class="bi bi-image text-white-50 fs-1"></i>
                                            <span class="text-muted small">Sin GIF asignado</span>
                                        </div>
                                    }
                                </div>

                                <h4 class="text-white fw-black mb-2">@ejercicioSeleccionado.Nombre</h4>
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <span class="badge bg-primary text-dark rounded-pill px-3 py-2">@ejercicioSeleccionado.GrupoMuscularPrincipal</span>
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-3 py-2">@ejercicioSeleccionado.Equipo</span>
                                    <span class="badge bg-secondary bg-opacity-10 text-white-50 border border-secondary border-opacity-25 rounded-pill px-3 py-2">@ejercicioSeleccionado.Nivel</span>
                                </div>

                                <div class="instruction-box mb-3">
                                    <span class="box-label">Instrucciones</span>
                                    <p>@ejercicioSeleccionado.Instrucciones</p>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(ejercicioSeleccionado.ErroresComunes))
                                {
                                    <div class="instruction-box danger mb-3">
                                        <span class="box-label">Evitar</span>
                                        <p>@ejercicioSeleccionado.ErroresComunes</p>
                                    </div>
                                }

                                <div class="assignment-box">
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <label class="form-label">Series</label>
                                            <input type="number" min="1" class="form-control control-dark" @bind="seriesInput" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Reps</label>
                                            <input class="form-control control-dark" @bind="repsInput" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Descanso</label>
                                            <input type="number" min="0" class="form-control control-dark" @bind="descansoInput" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">RIR/RPE</label>
                                            <input class="form-control control-dark" @bind="rirInput" placeholder="2 RIR" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Notas para el atleta</label>
                                            <textarea class="form-control control-dark" rows="2" @bind="notasCoachInput" placeholder="Top set, rango, tecnica, progresion..."></textarea>
                                        </div>
                                    </div>

                                    <button class="btn btn-gradient w-100 rounded-pill fw-black mt-3 py-2" @onclick="AgregarEjercicioDesdeCatalogo">
                                        <i class="bi bi-plus-circle-fill me-2"></i>Asignar al dia
                                    </button>
                                </div>
                            }
                        </div>

                        <div class="panel builder-panel">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <h5 class="text-white fw-black mb-1">Constructor semanal</h5>
                                    <span class="text-muted small">Organiza dias y ejercicios.</span>
                                </div>
                                <button class="btn btn-outline-primary rounded-pill fw-bold px-4" @onclick="GuardarRutinaEnBD" disabled="@guardandoRutina">
                                    @if (guardandoRutina)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-cloud-check me-2"></i>
                                    }
                                    Guardar
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(mensajeRutina))
                            {
                                <div class="alert alert-success bg-success bg-opacity-10 border-success text-success rounded-3 py-2 small">
                                    <i class="bi bi-check-circle-fill me-2"></i>@mensajeRutina
                                </div>
                            }

                            <div class="day-strip custom-scrollbar mb-3">
                                @foreach (var dia in rutinaActual.Dias.OrderBy(d => d.OrdenDia))
                                {
                                    <button class="day-chip @(dia.NombreDia == diaSeleccionado ? "active" : "")" @onclick="() => SeleccionarDia(dia.NombreDia)">
                                        @dia.NombreDia
                                        <span>@dia.Ejercicios.Count</span>
                                    </button>
                                }
                            </div>

                            <div class="input-group mb-3">
                                <input class="form-control control-dark" placeholder="Ej: Dia 3 - Pierna" @bind="nuevoDiaNombre" />
                                <button class="btn btn-outline-info fw-bold" @onclick="AgregarDia"><i class="bi bi-plus-lg"></i></button>
                            </div>

                            @{
                                var diaActual = rutinaActual.Dias.FirstOrDefault(d => d.NombreDia == diaSeleccionado);
                            }

                            @if (diaActual == null)
                            {
                                <div class="empty-state compact">
                                    <i class="bi bi-calendar-plus text-white-50 fs-1"></i>
                                    <p class="text-muted small mb-0 mt-2">Crea un dia para empezar.</p>
                                </div>
                            }
                            else if (!diaActual.Ejercicios.Any())
                            {
                                <div class="empty-state compact">
                                    <i class="bi bi-clipboard-plus text-white-50 fs-1"></i>
                                    <p class="text-muted small mb-0 mt-2">Este dia todavia no tiene ejercicios.</p>
                                </div>
                            }
                            else
                            {
                                <div class="assigned-list custom-scrollbar">
                                    @foreach (var ejercicio in diaActual.Ejercicios.OrderBy(e => e.Orden))
                                    {
                                        <div class="assigned-card">
                                            <div class="d-flex justify-content-between gap-3">
                                                <div>
                                                    <h6 class="text-white fw-bold mb-1">@ejercicio.NombreEjercicio</h6>
                                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                                        <span class="mini-badge">@ejercicio.Series series</span>
                                                        <span class="mini-badge">@ejercicio.Repeticiones reps</span>
                                                        <span class="mini-badge">@ejercicio.DescansoSegundos s</span>
                                                        @if (!string.IsNullOrWhiteSpace(ejercicio.RIR))
                                                        {
                                                            <span class="mini-badge">@ejercicio.RIR</span>
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(ejercicio.NotasCoach))
                                                    {
                                                        <p class="text-muted small mb-0">@ejercicio.NotasCoach</p>
                                                    }
                                                </div>
                                                <button class="icon-btn danger" @onclick="() => EliminarEjercicio(diaActual, ejercicio)" title="Eliminar ejercicio">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (tabActual == "progreso")
                {
                    <div class="progress-grid">
                        <div class="metric-card">
                            <span>Entrenamientos</span>
                            <strong>@historialEntrenamientos.Count</strong>
                        </div>
                        <div class="metric-card">
                            <span>Ultima sesion</span>
                            <strong>@UltimaSesionTexto</strong>
                        </div>
                        <div class="metric-card">
                            <span>Series registradas</span>
                            <strong>@historialEntrenamientos.Sum(r => r.EjerciciosHechos.Sum(e => e.Series.Count))</strong>
                        </div>
                    </div>

                    @if (!historialEntrenamientos.Any())
                    {
                        <div class="empty-state panel mt-4">
                            <i class="bi bi-graph-up display-6 text-white-50"></i>
                            <h5 class="text-white fw-bold mt-3">Sin historial aun</h5>
                            <p class="text-muted mb-0">Cuando el atleta cierre entrenamientos, apareceran aqui.</p>
                        </div>
                    }
                    else
                    {
                        <div class="history-list mt-4">
                            @foreach (var registro in historialEntrenamientos.OrderByDescending(r => r.FechaEntrenamiento))
                            {
                                <div class="panel history-card">
                                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                        <div>
                                            <h5 class="text-white fw-bold mb-1">@registro.NombreDiaEntrenado</h5>
                                            <span class="text-muted small">@registro.FechaEntrenamiento.ToString("dd/MM/yyyy h:mm tt")</span>
                                        </div>
                                        <span class="badge bg-primary text-dark rounded-pill">@registro.EjerciciosHechos.Count ejercicios</span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(registro.ComentariosAtleta))
                                    {
                                        <div class="coach-note mb-3">
                                            <span>Comentario del atleta</span>
                                            <p>@registro.ComentariosAtleta</p>
                                        </div>
                                    }

                                    @foreach (var ejercicio in registro.EjerciciosHechos)
                                    {
                                        <div class="history-exercise">
                                            <strong>@ejercicio.NombreEjercicio</strong>
                                            <div class="series-line">
                                                @foreach (var serie in ejercicio.Series)
                                                {
                                                    <span>@serie.NumeroSerie: @serie.PesoLibras lbs x @serie.RepeticionesLogradas</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
                else if (tabActual == "chat")
                {
                    <div class="chat-panel panel">
                        <div class="messages custom-scrollbar">
                            @if (!chatActual.Historial.Any())
                            {
                                <div class="empty-state compact">
                                    <i class="bi bi-chat-dots text-white-50 fs-1"></i>
                                    <p class="text-muted small mb-0 mt-2">Aun no hay mensajes.</p>
                                </div>
                            }
                            else
                            {
                                @foreach (var msg in chatActual.Historial)
                                {
                                    var esEntrenador = msg.RolRemitente == "Entrenador";
                                    <div class="message-row @(esEntrenador ? "out" : "in")">
                                        <div class="message-bubble">
                                            <p>@msg.Texto</p>
                                            <span>@msg.FechaEnvio.ToString("h:mm tt")</span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        <div class="chat-input">
                            <input class="form-control control-dark" placeholder="Escribe un mensaje..." @bind="nuevoMensajeTexto" @onkeyup="ManejarEnterChat" />
                            <button class="btn btn-gradient rounded-pill px-4" @onclick="EnviarMensaje"><i class="bi bi-send-fill"></i></button>
                        </div>
                    </div>
                }
            </section>
        }
    </main>
</div>

@if (mostrarModalEjercicio)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(4,5,8,.82); backdrop-filter: blur(8px);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content modal-surface">
                <div class="modal-header border-secondary border-opacity-25">
                    <h5 class="modal-title text-white fw-black"><i class="bi bi-database-add text-primary me-2"></i>Nuevo ejercicio de catalogo</h5>
                    <button class="btn-close btn-close-white" @onclick="CerrarModalEjercicio"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Nombre</label>
                            <input class="form-control control-dark" @bind="nuevoEjercicioCatalogo.Nombre" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Musculo principal</label>
                            <input class="form-control control-dark" @bind="nuevoEjercicioCatalogo.GrupoMuscularPrincipal" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Equipo</label>
                            <input class="form-control control-dark" @bind="nuevoEjercicioCatalogo.Equipo" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Nivel</label>
                            <select class="form-select control-dark" @bind="nuevoEjercicioCatalogo.Nivel">
                                <option>Principiante</option>
                                <option>Intermedio</option>
                                <option>Avanzado</option>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">URL GIF o imagen</label>
                            <input class="form-control control-dark" @bind="nuevoEjercicioCatalogo.GifUrl" placeholder="https://..." />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Instrucciones</label>
                            <textarea class="form-control control-dark" rows="3" @bind="nuevoEjercicioCatalogo.Instrucciones"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Errores comunes</label>
                            <textarea class="form-control control-dark" rows="2" @bind="nuevoEjercicioCatalogo.ErroresComunes"></textarea>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(errorCatalogo))
                    {
                        <div class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger rounded-3 mt-3 mb-0">
                            @errorCatalogo
                        </div>
                    }
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button class="btn btn-link text-muted text-decoration-none" @onclick="CerrarModalEjercicio">Cancelar</button>
                    <button class="btn btn-gradient rounded-pill fw-bold px-4" @onclick="GuardarEjercicioCatalogo">Guardar ejercicio</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .coach-shell {
        display: grid;
        grid-template-columns: 340px minmax(0, 1fr);
        min-height: calc(100vh - 6rem);
        gap: 1rem;
        font-family: 'Segoe UI', Roboto, sans-serif;
    }

    .coach-sidebar, .coach-workspace, .panel, .modal-surface {
        background: #0f141e;
