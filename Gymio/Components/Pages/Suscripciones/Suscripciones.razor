@page "/suscripciones"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer

@using Gymio.Models
@using Gymio.Interfaces
@inject ISuscripcionService SuscripcionService
@inject IClienteService ClienteService
@inject IPlanService PlanService

<div class="container-fluid py-5 bg-dark min-vh-100 text-white">
    <div class="container">
        
        <div class="row mb-5">
            <div class="col-12">
                <h2 class="fw-black text-white mb-1" style="letter-spacing: -1.5px;">
                    <span class="text-primary">💳</span> GESTIÓN DE SUSCRIPCIONES
                </h2>
                <p class="text-secondary fw-medium">Activa membresías y procesa pagos de socios.</p>
            </div>
        </div>

        <div class="row g-4">
            
            <div class="col-lg-5">
                <div class="card bg-secondary bg-opacity-10 border-0 rounded-4 shadow-lg p-4 border-top border-primary border-3">
                    <h5 class="fw-bold mb-4 text-uppercase small text-primary" style="letter-spacing: 1px;">Nueva Activación</h5>

                    @if (!string.IsNullOrEmpty(mensajeError))
                    {
                        <div class="alert alert-danger py-2 small border-0 mb-3">@mensajeError</div>
                    }

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small">1. BUSCAR SOCIO (NOMBRE / APELLIDO)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-0 text-muted"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control bg-dark border-0 text-white p-3" 
                                   placeholder="Escriba para filtrar..." @bind="busquedaCliente" @bind:event="oninput" />
                        </div>
                        
                        <div class="list-group mt-2 border-0 overflow-auto" style="max-height: 150px;">
                            @foreach (var c in clientesFiltrados)
                            {
                                <button type="button" @onclick="() => SeleccionarCliente(c)"
                                        class="list-group-item list-group-item-action bg-dark border-secondary border-opacity-10 text-white d-flex justify-content-between align-items-center @(clienteSeleccionadoId == c.Id ? "border-primary text-primary" : "")">
                                    <span>@c.Nombre @c.Apellido</span>
                                    <small class="text-muted">ID: @c.Id</small>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small">2. SELECCIONAR PLAN DE ENTRENAMIENTO</label>
                        <div class="row g-2">
                            @foreach (var p in planesDisponibles)
                            {
                                <div class="col-12">
                                    <button class="btn w-100 text-start p-3 border-0 @(planSeleccionadoId == p.Id ? "btn-primary shadow-orange" : "btn-dark text-secondary")"
                                            @onclick="() => planSeleccionadoId = p.Id">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <div class="fw-bold">@p.Nombre</div>
                                                <small class="opacity-75">Vigencia: @p.DuracionDias días</small>
                                            </div>
                                            <span class="fs-5 fw-black">C$@p.Precio.ToString("0.00")</span>
                                        </div>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small">3. MÉTODO DE PAGO</label>
                        <div class="d-flex gap-2">
                            @foreach (var m in MetodosPago)
                            {
                                <button class="btn btn-sm flex-fill py-2 fw-bold @(metodoPagoSeleccionado == m ? "btn-primary" : "btn-outline-secondary")"
                                        @onclick="() => metodoPagoSeleccionado = m">
                                    @m
                                </button>
                            }
                        </div>
                    </div>

                    <button class="btn btn-primary w-100 py-3 fw-black rounded-3 shadow-orange mt-2" 
                            disabled="@(clienteSeleccionadoId == 0 || planSeleccionadoId == 0)"
                            @onclick="ProcesarPago">
                        CONFIRMAR Y GENERAR RECIBO
                    </button>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card bg-secondary bg-opacity-10 border-0 rounded-4 p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Últimas Suscripciones</h5>
                        <span class="badge bg-dark text-primary border border-primary border-opacity-25 px-3 py-2">Tiempo Real</span>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-dark table-hover border-0 align-middle">
                            <thead>
                                <tr class="text-muted small border-bottom border-secondary">
                                    <th class="py-3">SOCIO</th>
                                    <th>PLAN</th>
                                    <th>VENCIMIENTO</th>
                                    <th class="text-end">ESTADO</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (suscripcionesRecientes == null)
                                {
                                    <tr><td colspan="4" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>
                                }
                                else if (!suscripcionesRecientes.Any())
                                {
                                    <tr><td colspan="4" class="text-center py-5 text-muted">No hay suscripciones activas hoy.</td></tr>
                                }
                                else
                                {
                                    @foreach (var s in suscripcionesRecientes)
                                    {
                                        <tr class="border-bottom border-secondary border-opacity-10">
                                            <td class="py-3">
                                                <div class="fw-bold">@s.Cliente?.Nombre @s.Cliente?.Apellido</div>
                                                <div class="small text-muted">Inició: @s.FechaInicio.ToShortDateString()</div>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                                    @s.Plan?.Nombre
                                                </span>
                                            </td>
                                            <td class="fw-medium text-info">@s.FechaVencimiento.ToShortDateString()</td>
                                            <td class="text-end">
                                                <span class="fw-black @(s.Estado == "Activa" ? "text-success" : "text-warning")">
                                                    ● @s.Estado.ToUpper()
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .shadow-orange { box-shadow: 0 4px 15px rgba(255, 107, 0, 0.4); }
    .fw-black { font-weight: 900 !important; }
    .btn-primary { background-color: #ff6b00; border-color: #ff6b00; color: white; }
    .btn-primary:hover { background-color: #e66000; border-color: #e66000; }
    .list-group-item-action:hover { background-color: #222 !important; }
</style>

@code {
    private string busquedaCliente = "";
    private int clienteSeleccionadoId;
    private int planSeleccionadoId;
    private string metodoPagoSeleccionado = "Efectivo";
    private string mensajeError = "";

    private List<Cliente> todosLosClientes = new();
    private List<Plan> planesDisponibles = new();
    private List<SuscripcionCliente> suscripcionesRecientes = new();
    private string[] MetodosPago = { "Efectivo", "Tarjeta", "Transferencia" };

    private IEnumerable<Cliente> clientesFiltrados => 
        string.IsNullOrWhiteSpace(busquedaCliente) 
            ? todosLosClientes.Take(5) 
            : todosLosClientes.Where(c => 
                c.Nombre.Contains(busquedaCliente, StringComparison.OrdinalIgnoreCase) || 
                c.Apellido.Contains(busquedaCliente, StringComparison.OrdinalIgnoreCase)).Take(5);

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        //cargar las listas
        todosLosClientes = await ClienteService.ObtenerClientesAsync();
        planesDisponibles = await PlanService.ObtenerPlanesAsync();
        suscripcionesRecientes = await SuscripcionService.ObtenerSuscripcionesRecientesAsync();
    }

    private void SeleccionarCliente(Cliente c)
    {
        clienteSeleccionadoId = c.Id;
        busquedaCliente = $"{c.Nombre} {c.Apellido}";
    }

    private async Task ProcesarPago()
    {
        try 
        {
            mensajeError = "";
            // usamos el ususario del admin que tiene id 2  para registrar la suscripcion
            bool exito = await SuscripcionService.RegistrarSuscripcionAsync(clienteSeleccionadoId, planSeleccionadoId, 2, metodoPagoSeleccionado);
            
            if (exito)
            {
                // se limpian las selecciones para una nueva transacción
                clienteSeleccionadoId = 0;
                planSeleccionadoId = 0;
                busquedaCliente = "";
                
                // actualizar historial
                await CargarDatos();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error en transacción: {ex.Message}";
        }
    }
}