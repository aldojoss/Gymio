@page "/suscripciones"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize (Roles = "Administrador")]
@rendermode InteractiveServer

@using Gymio.Models
@using Gymio.Interfaces
@inject ISuscripcionService SuscripcionService
@inject IClienteService ClienteService
@inject IPlanService PlanService

<div class="page-container p-4 fade-in">
    <div class="container-fluid max-w-custom">
        
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item text-muted">Operaciones</li>
                        <li class="breadcrumb-item active text-primary fw-bold" aria-current="page">Pagos y Planes</li>
                    </ol>
                </nav>
                <h2 class="fw-black text-white mb-0">Gestión de Suscripciones</h2>
                <span class="text-muted small tracking-widest text-uppercase">activa membresías y procesa pagos de socios</span>
            </div>
        </div>

        <div class="row g-4">
            
            @* PANEL IZQUIERDO: NUEVA ACTIVACIÓN *@
            <div class="col-lg-5">
                <div class="card border-secondary border-opacity-25 shadow-lg rounded-4 overflow-hidden h-100" style="background-color: #0f141e;">
                    <div class="bg-gradient-primary" style="height: 4px;"></div>
                    
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 text-white d-flex align-items-center">
                            <i class="bi bi-credit-card-fill text-primary me-2"></i> Nueva Activación
                        </h5>

                        @if (!string.IsNullOrEmpty(mensajeError))
                        {
                            <div class="alert alert-danger py-2 small border border-danger border-opacity-25 mb-4 slide-up text-danger" style="background-color: rgba(244, 63, 94, 0.1);">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i> @mensajeError
                            </div>
                        }

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">1. Buscar Socio</label>
                            <div class="input-group shadow-sm rounded-3 overflow-hidden border border-secondary border-opacity-50">
                                <span class="input-group-text bg-dark border-0 text-muted px-3"><i class="bi bi-search"></i></span>
                                @* Aquí está la corrección: llama al método BuscarSocio en cada tecla presionada *@
                                <input type="text" class="form-control bg-dark border-0 text-white shadow-none py-2" 
                                       placeholder="Nombre o apellido..." 
                                       value="@busquedaCliente" 
                                       @oninput="BuscarSocio" />
                            </div>
                            
                            @if (clientesFiltrados.Any())
                            {
                                <div class="list-group mt-2 border-0 custom-scrollbar overflow-auto rounded-3" style="max-height: 150px;">
                                    @foreach (var c in clientesFiltrados)
                                    {
                                        <button type="button" @onclick="() => SeleccionarCliente(c)"
                                                class="list-group-item list-group-item-action bg-dark text-white d-flex justify-content-between align-items-center transition-hover border-bottom border-secondary border-opacity-25 @(clienteSeleccionadoId == c.Id ? "selected-item" : "")">
                                            <span class="fw-medium">@c.Nombre @c.Apellido</span>
                                            <small class="opacity-75 font-monospace">#@c.Id.ToString("D4")</small>
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">2. Seleccionar Plan</label>
                            <div class="row g-2">
                                @foreach (var p in planesDisponibles)
                                {
                                    <div class="col-12">
                                        <button class="btn w-100 text-start p-3 rounded-3 transition-hover @(planSeleccionadoId == p.Id ? "plan-selected" : "plan-unselected")"
                                                @onclick="() => planSeleccionadoId = p.Id">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <div class="fw-bold fs-6">@p.Nombre</div>
                                                    <small class="opacity-75"><i class="bi bi-clock me-1"></i> Vigencia: @p.DuracionDias días</small>
                                                </div>
                                                <span class="fs-5 fw-black font-monospace">C$@p.Precio.ToString("0.00")</span>
                                            </div>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">3. Método de Pago</label>
                            <div class="d-flex gap-2">
                                @foreach (var m in MetodosPago)
                                {
                                    <button class="btn btn-sm flex-fill py-2 fw-bold rounded-pill transition-hover @(metodoPagoSeleccionado == m ? "btn-gradient" : "btn-outline-secondary text-light border-secondary border-opacity-50")"
                                            @onclick="() => metodoPagoSeleccionado = m">
                                        @if(m == "Efectivo") { <i class="bi bi-cash-coin me-1"></i> }
                                        @if(m == "Tarjeta") { <i class="bi bi-credit-card me-1"></i> }
                                        @if(m == "Transferencia") { <i class="bi bi-phone-vibrate me-1"></i> }
                                        @m
                                    </button>
                                }
                            </div>
                        </div>

                        <button class="btn btn-gradient w-100 py-3 fw-bold rounded-pill shadow-sm transition-hover mt-2" 
                                disabled="@(clienteSeleccionadoId == 0 || planSeleccionadoId == 0)"
                                @onclick="ProcesarPago">
                            <i class="bi bi-check2-circle me-2"></i> CONFIRMAR Y GENERAR RECIBO
                        </button>
                    </div>
                </div>
            </div>

            @* PANEL DERECHO: ÚLTIMAS SUSCRIPCIONES *@
            <div class="col-lg-7">
                <div class="card border-secondary border-opacity-25 shadow-lg rounded-4 p-4 h-100" style="background-color: #0f141e;">
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0 text-white d-flex align-items-center">
                            <i class="bi bi-clock-history text-primary me-2"></i> Últimas Suscripciones
                        </h5>
                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 rounded-pill shadow-sm">
                            <span class="spinner-grow spinner-grow-sm me-1" role="status" style="width: 0.7rem; height: 0.7rem;"></span> Tiempo Real
                        </span>
                    </div>

                    <div class="table-responsive custom-scrollbar pb-2">
                        <table class="table modern-table table-borderless align-middle mb-0" style="min-width: 600px;">
                            <thead>
                                <tr class="text-muted text-uppercase small tracking-widest" style="font-size: 0.75rem;">
                                    <th class="ps-4 pb-3">Socio</th>
                                    <th class="pb-3">Plan</th>
                                    <th class="pb-3">Vencimiento</th>
                                    <th class="text-end pe-4 pb-3">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (suscripcionesRecientes == null)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <div class="spinner-border text-primary mb-3" role="status"></div>
                                            <div>Cargando historial...</div>
                                        </td>
                                    </tr>
                                }
                                else if (!suscripcionesRecientes.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <div class="bg-dark d-inline-block p-4 rounded-circle mb-3 border border-secondary border-opacity-25">
                                                <i class="bi bi-receipt display-4 text-white-50"></i>
                                            </div>
                                            <h6 class="text-white">No hay actividad reciente</h6>
                                            <p class="small">Las suscripciones de hoy aparecerán aquí.</p>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var s in suscripcionesRecientes)
                                    {
                                        <tr class="modern-row slide-up">
                                            <td class="ps-4 py-3 rounded-start-4">
                                                <div class="fw-bold text-white">@s.Cliente?.Nombre @s.Cliente?.Apellido</div>
                                                <div class="small text-muted"><i class="bi bi-calendar-check me-1"></i> Inició: @s.FechaInicio.ToShortDateString()</div>
                                            </td>
                                            <td class="py-3">
                                                <span class="badge bg-dark text-light border border-secondary border-opacity-50 px-2 py-1">
                                                    @s.Plan?.Nombre
                                                </span>
                                            </td>
                                            <td class="py-3 text-light font-monospace small">
                                                @s.FechaVencimiento.ToShortDateString()
                                            </td>
                                            <td class="text-end pe-4 py-3 rounded-end-4">
                                                @if (s.Estado == "Activa")
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 fw-normal">
                                                        <i class="bi bi-circle-fill me-1" style="font-size: 0.4rem; vertical-align: middle;"></i> ACTIVA
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3 py-2 fw-normal">
                                                        <i class="bi bi-circle-fill me-1" style="font-size: 0.4rem; vertical-align: middle;"></i> @s.Estado.ToUpper()
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                        <tr class="row-spacer"><td colspan="4"></td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .page-container { font-family: 'Segoe UI', Roboto, sans-serif; }
    .max-w-custom { max-width: 1400px; margin: 0 auto; }
    .fw-black { font-weight: 900 !important; }
    .tracking-widest { letter-spacing: 0.1em; }
    
    .bg-gradient-primary { background: linear-gradient(135deg, #00FFA3, #00B8D4); }
    .text-primary { color: #00FFA3 !important; }
    .btn-gradient { background: linear-gradient(135deg, #00FFA3, #00B8D4); color: #040508; border: none; }
    .btn-gradient:hover:not(:disabled) { background: linear-gradient(135deg, #00e693, #00a5bf); color: #040508; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0, 255, 163, 0.3) !important; }
    .btn-gradient:disabled { opacity: 0.5; cursor: not-allowed; }

    .form-control:focus { background-color: rgba(255,255,255,0.05) !important; border-color: #00FFA3 !important; color: white !important; box-shadow: 0 0 0 0.25rem rgba(0, 255, 163, 0.25) !important; }
    .form-control::placeholder { color: #6c757d !important; opacity: 0.6; }
    
    .selected-item { background: linear-gradient(90deg, rgba(0, 255, 163, 0.1) 0%, rgba(0,0,0,0) 100%) !important; border-left: 3px solid #00FFA3 !important; color: #00FFA3 !important; }
    .list-group-item-action:hover:not(.selected-item) { background-color: #161d2b !important; }

    .plan-selected { background-color: rgba(0, 255, 163, 0.1); border: 1px solid #00FFA3; color: #00FFA3; box-shadow: 0 4px 15px rgba(0, 255, 163, 0.15); transform: translateY(-2px); }
    .plan-unselected { background-color: #161d2b; border: 1px solid rgba(255, 255, 255, 0.1); color: #94A3B8; }
    .plan-unselected:hover { border-color: rgba(255, 255, 255, 0.3); color: white; }

    .modern-table { border-collapse: separate; border-spacing: 0; }
    .modern-row td { background-color: rgba(255,255,255,0.02); border-top: 1px solid rgba(255, 255, 255, 0.02); border-bottom: 1px solid rgba(255, 255, 255, 0.02); transition: all 0.2s ease; }
    .modern-row td:first-child { border-left: 1px solid rgba(255, 255, 255, 0.02); }
    .modern-row td:last-child { border-right: 1px solid rgba(255, 255, 255, 0.02); }
    .row-spacer td { height: 10px; padding: 0; background: transparent; border: none; }
    .modern-row:hover td { background-color: #161d2b; transform: scale(1.005); }

    .transition-hover { transition: all 0.3s ease; }
    .fade-in { animation: fadeIn 0.4s ease-in-out; }
    .slide-up { animation: slideUp 0.3s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
    .custom-scrollbar::-webkit-scrollbar { height: 6px; width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0, 255, 163, 0.2); border-radius: 10px; }
</style>

@code {
    private string busquedaCliente = "";
    private int clienteSeleccionadoId;
    private int planSeleccionadoId;
    private string metodoPagoSeleccionado = "Efectivo";
    private string mensajeError = "";

    private List<Cliente> clientesFiltrados = new();
    private List<Plan> planesDisponibles = new();
    private List<SuscripcionCliente> suscripcionesRecientes = new();
    private string[] MetodosPago = { "Efectivo", "Tarjeta", "Transferencia" };

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        
        planesDisponibles = await PlanService.ObtenerPlanesAsync();
        suscripcionesRecientes = await SuscripcionService.ObtenerSuscripcionesRecientesAsync();
    }

    private async Task BuscarSocio(ChangeEventArgs e)
    {
        busquedaCliente = e.Value?.ToString() ?? "";

        if (string.IsNullOrWhiteSpace(busquedaCliente))
        {
            clientesFiltrados.Clear();
        }
        else
        {
            // no tomamos todos ya que se podria saturar
            clientesFiltrados = await ClienteService.BuscarClientesParaSuscripcionAsync(busquedaCliente);
        }
    }

    private void SeleccionarCliente(Cliente c)
    {
        clienteSeleccionadoId = c.Id;
        busquedaCliente = $"{c.Nombre} {c.Apellido}";
        clientesFiltrados.Clear(); // esconde la lista desplegable al seleccionar
    }

    private async Task ProcesarPago()
    {
        try 
        {
            mensajeError = "";
            bool exito = await SuscripcionService.RegistrarSuscripcionAsync(clienteSeleccionadoId, planSeleccionadoId, 2, metodoPagoSeleccionado);
            
            if (exito)
            {
                clienteSeleccionadoId = 0;
                planSeleccionadoId = 0;
                busquedaCliente = "";
                clientesFiltrados.Clear();
                
                await CargarDatos();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error en transacción: {ex.Message}";
        }
    }
}