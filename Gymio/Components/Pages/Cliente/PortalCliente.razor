    .history-comment { background: rgba(255,255,255,.025); border-left: 3px solid #00FFA3; border-radius: .6rem; padding: .85rem; color: #e2e8f0; }
    .history-exercise { border-top: 1px solid rgba(255,255,255,.06); padding-top: .75rem; margin-top: .75rem; }
    .history-exercise strong { color: white; }
    .history-exercise div { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .5rem; }
