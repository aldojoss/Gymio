@page "/mi-portal"
@attribute [Authorize(Roles = "Cliente")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable

@using Gymio.Models
@using Gymio.Interfaces
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IRutinaService RutinaService
@inject IChatService ChatService
@inject IRegistroEntrenamientoService RegistroEntrenamientoService
@inject IClienteService ClienteService
@inject IEjercicioCatalogoService EjercicioCatalogoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Mi Entrenamiento - Gymio</PageTitle>

<div class="athlete-shell text-light">
    <header class="athlete-header">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
                <span class="eyebrow"><i class="bi bi-fire me-1"></i>Modo atleta</span>
                <h2 class="text-white fw-black mb-1">@nombreCliente</h2>
                @if (miRutina != null)
                {
                    <p class="text-muted mb-0">@miRutina.Titulo · @miRutina.Objetivo</p>
                }
            </div>
            <span class="athlete-avatar">@(string.IsNullOrWhiteSpace(nombreCliente) ? "G" : nombreCliente[..1].ToUpper())</span>
        </div>

        <div class="segmented-tabs">
            <button class="tab-btn @(tabActual == "entrenamiento" ? "active" : "")" @onclick='() => tabActual = "entrenamiento"'>
                <i class="bi bi-activity me-2"></i>Hoy
            </button>
            <button class="tab-btn @(tabActual == "historial" ? "active" : "")" @onclick='() => tabActual = "historial"'>
                <i class="bi bi-clock-history me-2"></i>Historial
            </button>
            <button class="tab-btn @(tabActual == "chat" ? "active" : "")" @onclick="AbrirChat">
                <i class="bi bi-chat-dots-fill me-2"></i>Chat
                @if (mensajesSinLeer > 0)
                {
                    <span class="chat-badge">@mensajesSinLeer</span>
                }
            </button>
        </div>
    </header>

    <main class="athlete-content custom-scrollbar">
        @if (cargando)
        {
            <div class="empty-state">
                <div class="spinner-border text-primary"></div>
            </div>
        }
        else if (tabActual == "entrenamiento")
        {
            @if (miRutina == null)
            {
                <div class="empty-state panel">
                    <i class="bi bi-clipboard-x display-5 text-white-50"></i>
                    <h4 class="text-white fw-black mt-3">Sin plan activo</h4>
                    <p class="text-muted mb-0">Tu entrenador aun no te ha asignado una rutina.</p>
                </div>
            }
            else
            {
                <section class="routine-summary panel mb-3">
                    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                        <div>
                            <h4 class="text-white fw-black mb-1">@miRutina.Titulo</h4>
                            <p class="text-muted mb-0">@miRutina.IndicacionesGenerales</p>
                        </div>
                        <div class="routine-date">
                            <span>@miRutina.FechaInicio.ToString("dd/MM")</span>
                            <i class="bi bi-arrow-right"></i>
                            <span>@miRutina.FechaFin.ToString("dd/MM")</span>
                        </div>
                    </div>
                </section>

                <div class="day-strip custom-scrollbar mb-3">
                    @foreach (var dia in miRutina.Dias.OrderBy(d => d.OrdenDia))
                    {
                        <button class="day-chip @(dia.NombreDia == diaSeleccionado ? "active" : "")" @onclick="() => CambiarDia(dia.NombreDia)">
                            @dia.NombreDia
                            <span>@dia.Ejercicios.Count</span>
                        </button>
                    }
                </div>

                @if (entrenamientoDeHoy.EjerciciosHechos.Any())
                {
                    var bloqueOriginal = miRutina.Dias.FirstOrDefault(d => d.NombreDia == diaSeleccionado);
                    var indice = 1;

                    @foreach (var ejercicioRegistro in entrenamientoDeHoy.EjerciciosHechos)
                    {
                        var ejercicioPlan = bloqueOriginal?.Ejercicios.FirstOrDefault(e => e.NombreEjercicio == ejercicioRegistro.NombreEjercicio);
                        var gifEjercicio = GifEjercicio(ejercicioPlan);

                        <article class="exercise-card panel">
                            <div class="exercise-media">
                                @if (!string.IsNullOrWhiteSpace(gifEjercicio))
                                {
                                    <img src="@gifEjercicio" alt="@ejercicioRegistro.NombreEjercicio" loading="lazy" referrerpolicy="no-referrer" />
                                }
                                else
                                {
                                    <div class="media-placeholder">
                                        <i class="bi bi-play-circle text-primary fs-1"></i>
                                        <span class="text-muted small">GIF pendiente</span>
                                    </div>
                                }
                            </div>

                            <div class="exercise-body">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <span class="exercise-count">Ejercicio @indice</span>
                                        <h4 class="text-white fw-black mb-2">@ejercicioRegistro.NombreEjercicio</h4>
                                        <div class="d-flex flex-wrap gap-2">
                                            @if (ejercicioPlan != null)
                                            {
                                                <span class="meta-badge">@ejercicioPlan.Series series</span>
                                                <span class="meta-badge">@ejercicioPlan.Repeticiones reps</span>
                                                <span class="meta-badge">@ejercicioPlan.DescansoSegundos s descanso</span>
                                                @if (!string.IsNullOrWhiteSpace(ejercicioPlan.RIR))
                                                {
                                                    <span class="meta-badge">@ejercicioPlan.RIR</span>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <span class="muscle-pill">@(ejercicioPlan?.GrupoMuscularPrincipal ?? "General")</span>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(ejercicioPlan?.InstruccionesTecnicas))
                                {
                                    <div class="instruction-box mb-3">
                                        <span>Instrucciones</span>
                                        <p>@ejercicioPlan.InstruccionesTecnicas</p>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(ejercicioPlan?.NotasCoach))
                                {
                                    <div class="instruction-box coach mb-3">
                                        <span>Nota del coach</span>
                                        <p>@ejercicioPlan.NotasCoach</p>
                                    </div>
                                }

                                <div class="tracker-table">
                                    <div class="tracker-head">
                                        <span>Set</span>
                                        <span>Lbs</span>
                                        <span>Reps</span>
                                        <span>RPE</span>
                                        <span></span>
                                    </div>

                                    @foreach (var serie in ejercicioRegistro.Series)
                                    {
                                        var serieKey = SerieKey(ejercicioRegistro, serie);
                                        var completada = seriesCompletadas.GetValueOrDefault(serieKey);

                                        <div class="tracker-row @(completada ? "done" : "")">
                                            <strong>@serie.NumeroSerie</strong>
                                            <input type="number" class="form-control tracker-input" @bind="serie.PesoLibras" disabled="@completada" placeholder="0" />
                                            <input type="number" class="form-control tracker-input" @bind="serie.RepeticionesLogradas" disabled="@completada" placeholder="0" />
                                            <input type="number" class="form-control tracker-input" @bind="serie.Rpe" disabled="@completada" placeholder="8" step="0.5" />
                                            <button class="check-btn @(completada ? "done" : "")" @onclick="() => ToggleSerie(serieKey)">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </article>

                        indice++;
                    }

                    <section class="finish-panel panel">
                        <label class="form-label">Comentarios del dia</label>
                        <textarea class="form-control control-dark mb-3" rows="2" @bind="entrenamientoDeHoy.ComentariosAtleta" placeholder="Como te sentiste, molestias, energia, observaciones..."></textarea>

                        @if (!string.IsNullOrWhiteSpace(mensajeConfirmacion))
                        {
                            <div class="alert @(guardadoCorrecto ? "alert-success" : "alert-warning") rounded-3 py-2 text-center fw-bold">
                                @mensajeConfirmacion
                            </div>
                        }

                        <button class="btn btn-gradient w-100 rounded-pill py-3 fw-black" @onclick="FinalizarEntrenamiento">
                            <i class="bi bi-trophy-fill me-2"></i>Finalizar entrenamiento
                        </button>
                    </section>
                }
                else
                {
                    <div class="empty-state panel">
                        <i class="bi bi-calendar-x display-5 text-white-50"></i>
                        <h4 class="text-white fw-black mt-3">Dia sin ejercicios</h4>
                        <p class="text-muted mb-0">Tu entrenador aun no agrego ejercicios a este bloque.</p>
                    </div>
                }
            }
        }
        else if (tabActual == "historial")
        {
            @if (!historialEntrenamientos.Any())
            {
                <div class="empty-state panel">
                    <i class="bi bi-clock-history display-5 text-white-50"></i>
                    <h4 class="text-white fw-black mt-3">Sin historial</h4>
                    <p class="text-muted mb-0">Tus entrenamientos guardados apareceran aqui.</p>
                </div>
            }
            else
            {
                <div class="history-list">
                    @foreach (var registro in historialEntrenamientos)
                    {
                        <article class="panel history-card">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <h5 class="text-white fw-bold mb-1">@registro.NombreDiaEntrenado</h5>
                                    <span class="text-muted small">@registro.FechaEntrenamiento.ToString("dd/MM/yyyy h:mm tt")</span>
                                </div>
                                <span class="badge bg-primary text-dark rounded-pill">@registro.EjerciciosHechos.Sum(e => e.Series.Count) series</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(registro.ComentariosAtleta))
                            {
                                <p class="history-comment">@registro.ComentariosAtleta</p>
                            }

                            @foreach (var ejercicio in registro.EjerciciosHechos)
                            {
                                <div class="history-exercise">
                                    <strong>@ejercicio.NombreEjercicio</strong>
                                    <div>
                                        @foreach (var serie in ejercicio.Series)
                                        {
                                            <span>@serie.NumeroSerie: @serie.PesoLibras lbs x @serie.RepeticionesLogradas</span>
                                        }
                                    </div>
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        }
        else if (tabActual == "chat")
        {
            <section class="chat-panel panel">
                <div class="messages custom-scrollbar">
                    @if (!chatActual.Historial.Any())
                    {
                        <div class="empty-state compact">
                            <i class="bi bi-chat-heart text-white-50 fs-1"></i>
                            <p class="text-muted small mb-0 mt-2">Comunicate con tu entrenador.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var msg in chatActual.Historial)
                        {
                            var esCliente = msg.RolRemitente == "Cliente";
                            <div class="message-row @(esCliente ? "out" : "in")">
                                <div class="message-bubble">
                                    <p>@msg.Texto</p>
                                    <span>@msg.FechaEnvio.ToString("h:mm tt")</span>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="chat-input">
                    <input class="form-control control-dark" placeholder="Mensaje..." @bind="nuevoMensajeTexto" @onkeyup="ManejarEnterChat" />
                    <button class="btn btn-gradient rounded-pill px-4" @onclick="EnviarMensaje">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </section>
        }
    </main>
</div>

<style>
    .athlete-shell {
        min-height: calc(100vh - 6rem);
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        gap: 1rem;
        font-family: 'Segoe UI', Roboto, sans-serif;
    }

    .athlete-header, .panel {
        background: #0f141e;
        border: 1px solid rgba(255,255,255,.06);
        border-radius: 1rem;
        box-shadow: 0 14px 30px rgba(0,0,0,.18);
    }

    .athlete-header { padding: 1.25rem; }
    .athlete-content { overflow: auto; padding-bottom: 1rem; }
    .fw-black { font-weight: 900 !important; }
    .text-primary { color: #00FFA3 !important; }
    .bg-primary { background-color: #00FFA3 !important; }
    .eyebrow { color: #00FFA3; font-size: .75rem; font-weight: 900; text-transform: uppercase; }
    .athlete-avatar { width: 52px; height: 52px; border-radius: 50%; background: linear-gradient(135deg, #00FFA3, #00B8D4); color: #041014; display: inline-flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.2rem; }

    .segmented-tabs { background: rgba(0,0,0,.28); border: 1px solid rgba(255,255,255,.08); border-radius: 999px; padding: .25rem; display: flex; gap: .25rem; }
    .tab-btn { position: relative; flex: 1; border: 0; background: transparent; color: #94a3b8; border-radius: 999px; padding: .75rem .9rem; font-weight: 900; }
    .tab-btn.active { background: #00FFA3; color: #041014; }
    .chat-badge { position: absolute; top: -6px; right: 8px; background: #f43f5e; color: white; border-radius: 999px; min-width: 20px; height: 20px; font-size: .7rem; display: inline-flex; align-items: center; justify-content: center; }

    .panel { padding: 1.25rem; }
    .empty-state { min-height: 340px; display: flex; align-items: center; justify-content: center; flex-direction: column; text-align: center; padding: 2rem; }
    .empty-state.compact { min-height: 240px; }
    .routine-date { display: flex; align-items: center; gap: .65rem; color: #cbd5e1; background: #111827; border: 1px solid rgba(255,255,255,.06); border-radius: 999px; padding: .65rem 1rem; font-weight: 800; white-space: nowrap; }
    .day-strip { display: flex; gap: .5rem; overflow-x: auto; padding-bottom: .35rem; }
    .day-chip { border: 1px solid rgba(255,255,255,.08); color: #cbd5e1; background: #111827; border-radius: 999px; padding: .65rem .85rem; white-space: nowrap; font-weight: 900; }
    .day-chip.active { background: #00FFA3; color: #041014; border-color: #00FFA3; }
    .day-chip span { margin-left: .5rem; opacity: .72; }

    .exercise-card { display: grid; grid-template-columns: 260px minmax(0,1fr); gap: 1.25rem; margin-bottom: 1rem; }
    .exercise-media { min-height: 230px; border-radius: .9rem; background: #111827; border: 1px solid rgba(255,255,255,.06); overflow: hidden; }
    .exercise-media img { width: 100%; height: 100%; object-fit: contain; display: block; background: #0b111d; }
    .media-placeholder { height: 100%; min-height: 230px; display: flex; flex-direction: column; gap: .5rem; align-items: center; justify-content: center; }
    .exercise-count { color: #94a3b8; font-size: .75rem; font-weight: 900; text-transform: uppercase; }
    .meta-badge, .muscle-pill { border-radius: 999px; padding: .35rem .7rem; font-size: .78rem; font-weight: 800; }
    .meta-badge { background: rgba(0,255,163,.08); color: #00FFA3; border: 1px solid rgba(0,255,163,.2); }
    .muscle-pill { background: #00FFA3; color: #041014; white-space: nowrap; }
    .instruction-box { background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.06); border-radius: .85rem; padding: 1rem; }
    .instruction-box.coach { border-color: rgba(0,255,163,.22); }
    .instruction-box span { color: #94a3b8; font-size: .72rem; text-transform: uppercase; font-weight: 900; display: block; margin-bottom: .35rem; }
    .instruction-box p { color: #e2e8f0; margin: 0; }

    .tracker-table { display: grid; gap: .5rem; }
    .tracker-head, .tracker-row { display: grid; grid-template-columns: 52px minmax(0,1fr) minmax(0,1fr) minmax(0,1fr) 48px; gap: .5rem; align-items: center; }
    .tracker-head { color: #94a3b8; font-size: .72rem; font-weight: 900; text-transform: uppercase; padding: 0 .2rem; }
