@page "/mi-portal"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = "Cliente")]
@implements IAsyncDisposable

@using Gymio.Models
@using Gymio.Interfaces
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

@inject IChatService ChatService
@inject IClienteService ClienteService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="gymio-mobile-app vh-100 d-flex flex-column text-light overflow-hidden">
    
    <div class="mobile-header sticky-top z-3">
        <div class="header-content p-4 d-flex justify-content-between align-items-center">
            <div>
                <span class="text-uppercase tracking-widest small opacity-75 text-primary fw-bold">GYMIO SOCIO</span>
                <h2 class="fw-black text-white mb-0 mt-1">@miPerfil.Nombre</h2>
            </div>
            <div class="avatar-ring p-1 rounded-circle bg-gradient-primary">
                <div class="avatar bg-dark text-white d-flex justify-content-center align-items-center rounded-circle border border-dark border-3 fw-bold fs-4" style="width: 55px; height: 55px;">
                    @(miPerfil.Nombre?.Substring(0,1) ?? "U")
                </div>
            </div>
        </div>
        
        <div class="d-flex px-4 pb-3 gap-2">
            <button class="nav-btn flex-grow-1 p-2 rounded-4 fw-bold transition-all @(tabActual == "rutina" ? "nav-active" : "nav-inactive")" @onclick='() => tabActual = "rutina"'>
                <i class="bi bi-fire fs-5 d-block mb-1"></i> Rutina
            </button>
            <button class="nav-btn flex-grow-1 p-2 rounded-4 fw-bold transition-all @(tabActual == "chat" ? "nav-active" : "nav-inactive")" @onclick='() => tabActual = "chat"'>
                <i class="bi bi-chat-square-text-fill fs-5 d-block mb-1"></i> Coach
            </button>
        </div>
    </div>

    <div class="app-body flex-grow-1 position-relative overflow-auto p-3 custom-scrollbar" style="height: 0; background-image: radial-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px); background-size: 20px 20px;">
        
        @if (!string.IsNullOrEmpty(mensajeError))
        {
            @* este es el aviso por si algo sale mal asi no se congela la pantalla *@
            <div class="alert alert-warning m-3 text-center shadow-sm rounded-4 border-warning border-opacity-50" style="background-color: rgba(255, 193, 7, 0.1);">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-1 mb-2 d-block"></i>
                <p class="text-white mb-0">@mensajeError</p>
            </div>
        }

        @if (tabActual == "rutina")
        {
            <div class="d-flex flex-column align-items-center justify-content-center h-100 text-center fade-in">
                <div class="rounded-circle bg-dark p-4 mb-3 border border-secondary border-opacity-50 shadow-lg">
                    <i class="bi bi-dumbbell display-4 text-white-50"></i>
                </div>
                <h4 class="fw-bold">Día de Hipertrofia</h4>
                <p class="text-white-50 px-4">Tu entrenador está preparando tu bloque de esta semana.</p>
            </div>
        }
        else if (tabActual == "chat")
        {
            <div class="d-flex flex-column gap-3 pb-4 fade-in">
                <div class="text-center mb-2">
                    <span class="badge bg-dark bg-opacity-75 text-white-50 px-3 py-2 rounded-pill border border-secondary border-opacity-25 shadow-sm">
                        <i class="bi bi-lock-fill me-1"></i> Conexión privada
                    </span>
                </div>

                @if (chatActual?.Historial != null)
                {
                    @foreach (var msg in chatActual.Historial)
                    {
                        bool soyYo = msg.RolRemitente == "Cliente";
                        <div class="d-flex w-100 @(soyYo ? "justify-content-end" : "justify-content-start") slide-up">
                            <div class="p-3 shadow-md msg-bubble @(soyYo ? "mi-bubble" : "coach-bubble")">
                                <div style="line-height: 1.4;">@msg.Texto</div>
                                <div class="msg-meta text-end mt-1 d-flex justify-content-end align-items-center gap-1">
                                    @msg.FechaEnvio.ToString("h:mm tt")
                                    @if (soyYo) { <i class="bi bi-check2-all text-white-50"></i> }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        }
    </div>

    @if (tabActual == "chat" && string.IsNullOrEmpty(mensajeError))
    {
        <div class="chat-input-wrapper p-3 sticky-bottom slide-up z-3">
            <div class="input-group shadow-lg rounded-pill p-1 bg-dark border border-secondary border-opacity-50" style="backdrop-filter: blur(10px);">
                <input type="text" class="form-control bg-transparent border-0 text-white shadow-none px-4 py-2" 
                       placeholder="Mensaje..." @bind="nuevoMensajeTexto" @onkeyup="@(e => { if(e.Key == "Enter") EnviarMensaje(); })" />
                <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm transition-hover" @onclick="EnviarMensaje">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>
    }
</div>

<style>
    /* tus estilos cyber mint se quedan igual mayfren */
    .gymio-mobile-app { background-color: #040508; font-family: 'Segoe UI', Roboto, sans-serif; }
    .bg-gradient-primary { background: linear-gradient(135deg, #00FFA3, #00B8D4); color: #000 !important; }
    .text-primary { color: #00FFA3 !important; }
    .mobile-header { background: rgba(8, 10, 15, 0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0, 255, 163, 0.1); }
    .nav-btn { border: none; font-size: 0.85rem; }
    .nav-active { background: linear-gradient(135deg, #00FFA3, #00B8D4); color: #041014; font-weight: 700 !important; box-shadow: 0 4px 15px rgba(0, 255, 163, 0.25); }
    .nav-inactive { background: rgba(255,255,255,0.03); color: #6c757d; border: 1px solid rgba(255,255,255,0.05); }
    .msg-bubble { max-width: 85%; font-size: 0.95rem; }
    .mi-bubble { background: linear-gradient(135deg, #00FFA3, #00B8D4); color: #041014; font-weight: 500; border-radius: 1.2rem 1.2rem 0 1.2rem; box-shadow: 0 4px 15px rgba(0, 255, 163, 0.2); }
    .coach-bubble { background: #12151f; color: #e0e4f5; border-radius: 1.2rem 1.2rem 1.2rem 0; border: 1px solid #1f2538; }
    .msg-meta { font-size: 0.7rem; opacity: 0.8; }
    .fade-in { animation: fadeIn 0.4s ease-in-out; }
    .slide-up { animation: slideUp 0.3s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .btn-success { background-color: #00FFA3 !important; border-color: #00FFA3 !important; color: #000 !important; }
</style>

@code {
    private string tabActual = "chat";
    private Cliente miPerfil = new Cliente { Nombre = "Cargando..." };
    private ChatEntrenador chatActual = new ChatEntrenador { Historial = new List<Mensaje>() };
    private string nuevoMensajeTexto = "";
    private HubConnection? hubConnection;
    private string mensajeError = "";

    private int miIdCliente; 
    private int idDeMiCoach; 

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            @* primero sacamos el usuario que inicio sesion *@
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var usuarioLogueado = authState.User;

            if (usuarioLogueado.Identity is not null && usuarioLogueado.Identity.IsAuthenticated)
            {
                var claimId = usuarioLogueado.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                
                if (int.TryParse(claimId, out miIdCliente))
                {
                    @* cargamos los datos del cliente desde tu servicio *@
                    var clientes = await ClienteService.ObtenerClientesAsync("");
                    miPerfil = clientes.FirstOrDefault(c => c.Id == miIdCliente) ?? new Cliente { Nombre = "Socio" };

                    @* buscamos el coach asignado o el admin por defecto si la tabla esta vacia *@
                    idDeMiCoach = await ClienteService.ObtenerIdEntrenadorAsignadoAsync(miIdCliente);
                    
                    @* levantamos signalr y el chat de una vez *@
                    await PrepararChatYSignalR();
                }
            }
            else
            {
                @* si no esta logueado lo mandamos a volar al login *@
                Nav.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            @* cpaturartheerror *@
            mensajeError = "estamos terminando de configurar tu perfil vuelve a intentar en un momento";
            Console.WriteLine($"error en el portal cliente {ex.Message}");
        }
    }

    private async Task PrepararChatYSignalR()
    {
        @* cargamos el historial desde mongo usando tu servicio de chat *@
        chatActual = await ChatService.ObtenerOCrearChatAsync(miIdCliente, idDeMiCoach);
        
        @* inicializamos la lista por si mongo devolvio algo vacio asi no da error el foreach *@
        if (chatActual.Historial == null) chatActual.Historial = new List<Mensaje>();

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/chathub"))
            .Build();

        hubConnection.On<string>("ChatActualizado", async (chatId) =>
        {
            @* si alguien mas escribe actualizamos la lista en tiempo real *@
            if (chatActual != null && chatActual.Id == chatId)
            {
                chatActual = await ChatService.ObtenerOCrearChatAsync(miIdCliente, idDeMiCoach);
                await InvokeAsync(StateHasChanged);
            }
        });

        await hubConnection.StartAsync();
    }

    private async Task EnviarMensaje()
    {
        if (!string.IsNullOrWhiteSpace(nuevoMensajeTexto) && chatActual != null)
        {
            @* creamos el objeto mensaje con tus datos reales *@
            var msg = new Mensaje { 
                Texto = nuevoMensajeTexto, 
                RolRemitente = "Cliente", 
                RemitenteId = miIdCliente, 
                FechaEnvio = DateTime.Now 
            };

            @* guardamos en mongo y avisamos por signalr *@
            await ChatService.EnviarMensajeAsync(chatActual.Id!, msg);
            
            if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
            {
                await hubConnection.SendAsync("NotificarNuevoMensaje", chatActual.Id);
            }

            @* actualizamos la interfaz local para que se vea al instante *@
            chatActual.Historial.Add(msg);
            nuevoMensajeTexto = "";
        }
    }

    public async ValueTask DisposeAsync()
    {
        @* cerramos la radio al salir de la pagina para no gastar recursos *@
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}