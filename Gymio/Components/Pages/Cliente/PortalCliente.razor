    .message-row.out .message-bubble { background: linear-gradient(135deg, #00FFA3, #00B8D4); color: #041014; }
    .message-bubble p { margin: 0 0 .35rem; }
    .message-bubble span { font-size: .72rem; opacity: .7; display: block; text-align: right; }
    .chat-input { display: flex; gap: .75rem; border-top: 1px solid rgba(255,255,255,.06); padding-top: 1rem; }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,.14); border-radius: 999px; }

    @@media (max-width: 900px) {
        .exercise-card { grid-template-columns: 1fr; }
        .segmented-tabs { overflow-x: auto; }
        .tab-btn { min-width: 120px; }
        .routine-date { align-self: flex-start; }
    }
</style>

@code {
    private int idClienteActual;
    private int idEntrenadorAsignado;
    private string nombreCliente = "";
    private bool cargando = true;
    private string tabActual = "entrenamiento";
    private Rutina? miRutina;
    private string diaSeleccionado = "";
    private RegistroEntrenamiento entrenamientoDeHoy = new();
    private List<RegistroEntrenamiento> historialEntrenamientos = new();
    private Dictionary<string, bool> seriesCompletadas = new();
    private ChatEntrenador chatActual = new();
    private string nuevoMensajeTexto = "";
    private HubConnection? hubConnection;
    private int mensajesSinLeer;
    private string mensajeConfirmacion = "";
    private bool guardadoCorrecto;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is not null && user.Identity.IsAuthenticated)
        {
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
            var nameClaim = user.FindFirst(ClaimTypes.Name);
            if (userIdClaim != null)
            {
                idClienteActual = int.Parse(userIdClaim.Value);
                nombreCliente = nameClaim?.Value ?? "Atleta";
            }
        }

        miRutina = await RutinaService.ObtenerRutinaActivaAsync(idClienteActual);
        if (miRutina != null)
        {
            await HidratarRutinaConCatalogoAsync(miRutina);
        }

        historialEntrenamientos = await RegistroEntrenamientoService.ObtenerPorClienteAsync(idClienteActual, 20);

        if (miRutina != null && miRutina.Dias.Any())
        {
            diaSeleccionado = miRutina.Dias.OrderBy(d => d.OrdenDia).First().NombreDia;
            idEntrenadorAsignado = miRutina.EntrenadorId;
            PrepararRegistroDeHoy();
        }

        if (idEntrenadorAsignado == 0)
        {
            idEntrenadorAsignado = await ClienteService.ObtenerIdEntrenadorAsignadoAsync(idClienteActual);
        }

        if (idEntrenadorAsignado > 0)
        {
            chatActual = await ChatService.ObtenerOCrearChatAsync(idClienteActual, idEntrenadorAsignado);
            mensajesSinLeer = chatActual.Historial.Count(m => m.RolRemitente == "Entrenador" && !m.Leido);
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/chathub"))
            .Build();

        hubConnection.On<string>("ChatActualizado", async chatId =>
        {
            if (!string.IsNullOrWhiteSpace(chatActual.Id) && chatActual.Id == chatId && idEntrenadorAsignado > 0)
            {
                chatActual = await ChatService.ObtenerOCrearChatAsync(idClienteActual, idEntrenadorAsignado);
                if (tabActual == "chat")
                {
                    await MarcarMensajesComoLeidos();
                }
                else
                {
                    mensajesSinLeer = chatActual.Historial.Count(m => m.RolRemitente == "Entrenador" && !m.Leido);
                }

                await InvokeAsync(StateHasChanged);
            }
        });

        await hubConnection.StartAsync();
        cargando = false;
    }

    private void CambiarDia(string nombreDia)
    {
        diaSeleccionado = nombreDia;
        mensajeConfirmacion = "";
        guardadoCorrecto = false;
        PrepararRegistroDeHoy();
    }

    private void PrepararRegistroDeHoy()
    {
        seriesCompletadas.Clear();

        entrenamientoDeHoy = new RegistroEntrenamiento
        {
            ClienteId = idClienteActual,
            RutinaId = miRutina?.Id ?? "",
            NombreDiaEntrenado = diaSeleccionado,
            FechaEntrenamiento = DateTime.Now,
            EjerciciosHechos = new List<RegistroEjercicio>()
        };

        var bloqueOriginal = miRutina?.Dias.FirstOrDefault(d => d.NombreDia == diaSeleccionado);
        if (bloqueOriginal == null)
        {
            return;
        }

        foreach (var ejercicio in bloqueOriginal.Ejercicios.OrderBy(e => e.Orden))
        {
            var registroEjercicio = new RegistroEjercicio
            {
                EjercicioCatalogoId = ejercicio.EjercicioCatalogoId,
                NombreEjercicio = ejercicio.NombreEjercicio,
                GrupoMuscularPrincipal = ejercicio.GrupoMuscularPrincipal,
                Equipo = ejercicio.Equipo,
                NotasCoach = ejercicio.NotasCoach,
                Series = new List<RegistroSerie>()
            };

            for (var i = 1; i <= Math.Max(1, ejercicio.Series); i++)
            {
                registroEjercicio.Series.Add(new RegistroSerie { NumeroSerie = i });
            }

            entrenamientoDeHoy.EjerciciosHechos.Add(registroEjercicio);
        }
    }

    private async Task HidratarRutinaConCatalogoAsync(Rutina rutina)
    {
        foreach (var ejercicio in rutina.Dias.SelectMany(d => d.Ejercicios))
        {
            var necesitaVisual = string.IsNullOrWhiteSpace(ejercicio.GifUrl);
            var necesitaTecnica = string.IsNullOrWhiteSpace(ejercicio.InstruccionesTecnicas);

            if (!necesitaVisual && !necesitaTecnica)
            {
                continue;
            }

            EjercicioCatalogo? catalogo = null;

            if (!string.IsNullOrWhiteSpace(ejercicio.EjercicioCatalogoId))
            {
                catalogo = await EjercicioCatalogoService.ObtenerPorIdAsync(ejercicio.EjercicioCatalogoId);
            }

            if (catalogo == null || string.IsNullOrWhiteSpace(catalogo.GifUrl))
            {
                catalogo = await EjercicioCatalogoService.ResolverVisualPorNombreAsync(ejercicio.NombreEjercicio);
            }

            if (catalogo == null)
            {
                continue;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.GifUrl))
            {
                ejercicio.GifUrl = catalogo.GifUrl;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.InstruccionesTecnicas))
            {
                ejercicio.InstruccionesTecnicas = catalogo.Instrucciones;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.ErroresComunes))
            {
                ejercicio.ErroresComunes = catalogo.ErroresComunes;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.GrupoMuscularPrincipal))
            {
                ejercicio.GrupoMuscularPrincipal = catalogo.GrupoMuscularPrincipal;
            }

            if (string.IsNullOrWhiteSpace(ejercicio.Equipo))
            {
                ejercicio.Equipo = catalogo.Equipo;
            }
        }
    }

    private static string GifEjercicio(EjercicioRutina? ejercicio)
    {
        return ejercicio?.GifUrl ?? "";
    }

    private void ToggleSerie(string serieKey)
    {
        seriesCompletadas[serieKey] = !seriesCompletadas.GetValueOrDefault(serieKey);
    }

    private async Task FinalizarEntrenamiento()
    {
        var registroFinal = new RegistroEntrenamiento
        {
            ClienteId = entrenamientoDeHoy.ClienteId,
            RutinaId = entrenamientoDeHoy.RutinaId,
            NombreDiaEntrenado = entrenamientoDeHoy.NombreDiaEntrenado,
            FechaEntrenamiento = DateTime.Now,
            ComentariosAtleta = entrenamientoDeHoy.ComentariosAtleta,
            EjerciciosHechos = new List<RegistroEjercicio>()
        };

        foreach (var ejercicio in entrenamientoDeHoy.EjerciciosHechos)
        {
            var seriesCompletas = ejercicio.Series
                .Where(s => seriesCompletadas.GetValueOrDefault(SerieKey(ejercicio, s)))
                .ToList();

            if (seriesCompletas.Any())
            {
                registroFinal.EjerciciosHechos.Add(new RegistroEjercicio
                {
                    EjercicioCatalogoId = ejercicio.EjercicioCatalogoId,
                    NombreEjercicio = ejercicio.NombreEjercicio,
                    GrupoMuscularPrincipal = ejercicio.GrupoMuscularPrincipal,
                    Equipo = ejercicio.Equipo,
                    NotasCoach = ejercicio.NotasCoach,
                    Series = seriesCompletas
                });
            }
        }

        if (!registroFinal.EjerciciosHechos.Any())
        {
            guardadoCorrecto = false;
            mensajeConfirmacion = "Marca al menos una serie como completada antes de guardar.";
            return;
        }

        try
        {
            await RegistroEntrenamientoService.CrearRegistroAsync(registroFinal);
            historialEntrenamientos.Insert(0, registroFinal);
            guardadoCorrecto = true;
            mensajeConfirmacion = "Entrenamiento guardado correctamente.";
            PrepararRegistroDeHoy();
        }
        catch
        {
            guardadoCorrecto = false;
            mensajeConfirmacion = "Ocurrio un error al guardar el entrenamiento.";
        }
    }

    private async Task AbrirChat()
    {
        tabActual = "chat";
        await MarcarMensajesComoLeidos();
    }

    private async Task MarcarMensajesComoLeidos()
    {
        if (string.IsNullOrWhiteSpace(chatActual.Id))
        {
            return;
        }

        await ChatService.MarcarMensajesComoLeidosAsync(chatActual.Id, "Cliente");
        foreach (var msg in chatActual.Historial.Where(m => m.RolRemitente == "Entrenador"))
        {
            msg.Leido = true;
        }
        mensajesSinLeer = 0;
    }

    private async Task ManejarEnterChat(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await EnviarMensaje();
        }
    }

    private async Task EnviarMensaje()
    {
        if (string.IsNullOrWhiteSpace(nuevoMensajeTexto) || string.IsNullOrWhiteSpace(chatActual.Id))
        {
            return;
        }

        var msg = new Mensaje { Texto = nuevoMensajeTexto.Trim(), RolRemitente = "Cliente", RemitenteId = idClienteActual };
        await ChatService.EnviarMensajeAsync(chatActual.Id, msg);

        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
        {
            await hubConnection.SendAsync("NotificarNuevoMensaje", chatActual.Id);
        }

        chatActual.Historial.Add(msg);
        nuevoMensajeTexto = "";
    }

    private static string SerieKey(RegistroEjercicio ejercicio, RegistroSerie serie)
    {
        return $"{ejercicio.EjercicioCatalogoId ?? ejercicio.NombreEjercicio}-{serie.NumeroSerie}";
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
