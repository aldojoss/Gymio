    .tracker-row.done { border-color: rgba(0,255,163,.35); background: rgba(0,255,163,.07); }
    .tracker-row strong { text-align: center; color: #cbd5e1; }
    .tracker-input { background: transparent !important; border-color: rgba(255,255,255,.12) !important; color: white !important; text-align: center; box-shadow: none !important; }
    .tracker-input:focus { border-color: #00FFA3 !important; box-shadow: 0 0 0 .16rem rgba(0,255,163,.14) !important; }
    .check-btn { width: 40px; height: 40px; border-radius: .65rem; border: 1px solid rgba(255,255,255,.12); background: transparent; color: #94a3b8; }
    .check-btn.done { background: #00FFA3; color: #041014; border-color: #00FFA3; }

    .form-label { color: #94a3b8; font-size: .72rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0; }
