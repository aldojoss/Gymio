@page "/clientes"
@attribute [Authorize]
@rendermode InteractiveServer
@using Gymio.Models
@using Gymio.Interfaces
@inject IClienteService ClienteService
@inject IProfileImageService ProfileImageService
@inject IJSRuntime JS

<div class="page-container p-4 fade-in">
    
    @* encabezado moderno *@
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-black text-white mb-0">Directorio de Socios</h2>
            <span class="text-muted small tracking-widest text-uppercase">gestión y control de miembros</span>
        </div>
        
        <div class="d-flex gap-3 align-items-center w-100" style="max-width: 600px;">
            @* barra de busqueda estilo pildora *@
            <div class="input-group bg-dark border border-secondary border-opacity-25 rounded-pill overflow-hidden shadow-sm flex-grow-1">
                <span class="input-group-text bg-transparent border-0 text-muted ps-4">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control bg-transparent border-0 text-white shadow-none py-2" 
                       placeholder="Buscar por nombre o Código QR..." 
                       @bind="terminoBusqueda" @bind:event="oninput" @onkeyup="RealizarBusqueda" />
            </div>

            <a href="/nuevo-cliente" class="btn btn-gradient rounded-pill px-4 py-2 fw-bold shadow-sm transition-hover text-nowrap">
                <i class="bi bi-person-plus-fill me-2"></i> Nuevo Socio
            </a>
        </div>
    </div>

    @* tabla estilo tarjetas flotantes *@
    <div class="table-responsive custom-scrollbar pb-3">
        <table class="table modern-table table-borderless align-middle mb-0" style="min-width: 1000px;">
            <thead>
                <tr class="text-muted text-uppercase small tracking-widest" style="font-size: 0.75rem;">
                    <th class="ps-4 pb-3">Cliente</th>
                    <th class="pb-3">Contacto</th>
                    <th class="pb-3">Fecha de Ingreso</th>
                    <th class="pb-3">Coach</th> @* NUEVA COLUMNA *@
                    <th class="pb-3">Estado</th>
                    <th class="text-end pe-4 pb-3">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (listaClientes == null)
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <div class="spinner-border text-primary mb-3" role="status"></div>
                            <div>Cargando datos...</div>
                        </td>
                    </tr>
                }
                else if (!listaClientes.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <div class="bg-dark d-inline-block p-4 rounded-circle mb-3 border border-secondary border-opacity-25">
                                <i class="bi bi-people-fill display-4 text-white-50"></i>
                            </div>
                            <h5 class="text-white">No se encontraron clientes</h5>
                            <p class="small">Intenta con otro término de búsqueda</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var cliente in listaClientes)
                    {
                        <tr class="modern-row slide-up">
                            <td class="ps-4 py-3 rounded-start-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-sm bg-gradient-primary text-dark fw-bold rounded-circle d-flex align-items-center justify-content-center fs-5 shadow-sm overflow-hidden" style="width: 45px; height: 45px;">
                                        @if (!string.IsNullOrWhiteSpace(cliente.FotoUrl))
                                        {
                                            <img src="@cliente.FotoUrl" alt="Foto de @cliente.Nombre @cliente.Apellido" class="w-100 h-100 object-fit-cover" />
                                        }
                                        else
                                        {
                                            @(string.IsNullOrEmpty(cliente.Nombre) ? "U" : cliente.Nombre.Substring(0,1).ToUpper())
                                        }
                                    </div>
                                    <div>
                                        <div class="fw-bold text-white" style="font-size: 1.05rem;">@cliente.Nombre @cliente.Apellido</div>
                                        <div class="text-muted small font-monospace"><i class="bi bi-qr-code me-1"></i> @cliente.CodigoQR</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="text-light mb-1">
                                    <i class="bi bi-telephone-fill text-muted me-2 small"></i>
                                    @(string.IsNullOrEmpty(cliente.Telefono) ? "Sin teléfono" : cliente.Telefono)
                                </div>
                                <div class="text-muted small">
                                    <i class="bi bi-envelope-fill me-2"></i>
                                    @(string.IsNullOrEmpty(cliente.Email) ? "Sin correo" : cliente.Email)
                                </div>
                            </td>
                            <td class="py-3 text-light">
                                <i class="bi bi-calendar3 text-muted me-2 small"></i>
                                @cliente.FechaRegistro.ToString("dd/MMM/yyyy")
                            </td>
                            
                            @* CELDA DEL COACH ASIGNADO *@
                            <td class="py-3">
                                @if (asignacionesClientes.TryGetValue(cliente.Id, out int coachId) && nombresEntrenadores.TryGetValue(coachId, out string nombreCoach))
                                {
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-3 py-2 fw-normal">
                                        <i class="bi bi-person-check-fill me-1"></i> @nombreCoach
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-white-50 border border-secondary border-opacity-25 rounded-pill px-3 py-2 fw-normal">
                                        <i class="bi bi-person-x me-1"></i> Sin Asignar
                                    </span>
                                }
                            </td>

                            <td class="py-3">
                                @if (cliente.Activo)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 fw-normal">
                                        <i class="bi bi-circle-fill me-1" style="font-size: 0.4rem; vertical-align: middle;"></i> Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2 fw-normal">
                                        <i class="bi bi-circle-fill me-1" style="font-size: 0.4rem; vertical-align: middle;"></i> Inactivo
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4 py-3 rounded-end-4">
                                <button class="btn btn-sm btn-outline-success fw-bold me-2 rounded-pill px-3 transition-hover" @onclick="() => AbrirModalAsignacion(cliente)">
                                    <i class="bi bi-person-badge me-1"></i> Coach
                                </button>
                                <button class="btn btn-sm btn-outline-info fw-bold rounded-pill px-3 transition-hover" @onclick="() => AbrirModalEdicion(cliente)">
                                    <i class="bi bi-pencil me-1"></i> Editar
                                </button>
                            </td>
                        </tr>
                        <tr class="row-spacer"><td colspan="6"></td></tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* MODAL DE EDICION *@
@if (mostrarModal)
{
    <div class="modal fade show d-block fade-in" tabindex="-1" style="background-color: rgba(4, 5, 8, 0.8); backdrop-filter: blur(8px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border border-secondary border-opacity-25 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-header border-bottom border-secondary border-opacity-25 p-4">
                    <h5 class="modal-title fw-black text-white d-flex align-items-center">
                        <div class="bg-gradient-info rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="bi bi-pencil-square text-dark fs-5"></i>
                        </div>
                        Editar Socio
                    </h5>
                    <button type="button" class="btn-close btn-close-white opacity-50 shadow-none" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrWhiteSpace(mensajeErrorModal))
                    {
                        <div class="alert alert-danger bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger py-2 small mb-3">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@mensajeErrorModal
                        </div>
                    }
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Foto del Socio</label>
                            <div id="foto-cliente-edicion-drop" class="upload-zone rounded-4 p-3 d-flex align-items-center gap-3">
                                <div class="profile-preview">
                                    @if (!string.IsNullOrWhiteSpace(fotoClientePreviewUrl) || !string.IsNullOrWhiteSpace(clienteActual.FotoUrl))
                                    {
                                        <img src="@(fotoClientePreviewUrl ?? clienteActual.FotoUrl)" alt="Foto de @clienteActual.Nombre @clienteActual.Apellido" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-circle"></i>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <InputFile id="foto-cliente-edicion-input" OnChange="SeleccionarFotoClienteEdicion" accept="image/png,image/jpeg,image/webp" class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" />
                                    <small class="text-muted d-block mt-2">
                                        JPG, PNG o WEBP. Se optimiza antes de guardar. También podés arrastrar o pegar la foto aquí.
                                        @if (!string.IsNullOrEmpty(nombreFotoClienteEdicion))
                                        {
                                            <span class="text-primary fw-bold ms-1">@nombreFotoClienteEdicion</span>
                                        }
                                    </small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Nombre</label>
                            <input type="text" class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="clienteActual.Nombre" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Apellido</label>
                            <input type="text" class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="clienteActual.Apellido" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Teléfono</label>
                            <input type="text" class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="clienteActual.Telefono" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Email</label>
                            <input type="email" class="form-control bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3" @bind="clienteActual.Email" />
                        </div>
                        <div class="col-12 mt-4">
                            <div class="form-check form-switch p-3 rounded-3 border border-secondary border-opacity-25" style="background-color: rgba(255,255,255,0.02);">
                                <input class="form-check-input ms-0 me-3" type="checkbox" id="estadoSocio" @bind="clienteActual.Activo" style="transform: scale(1.3);">
                                <label class="form-check-label fw-bold text-white mt-1" for="estadoSocio">
                                    @(clienteActual.Activo ? "El cliente tiene acceso permitido (Activo)" : "Acceso bloqueado (Inactivo)")
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-secondary border-opacity-25 p-4" style="background-color: rgba(255,255,255,0.02);">
                    <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold px-4" @onclick="CerrarModal">Cancelar</button>
                    <button type="button" class="btn btn-info fw-bold rounded-pill px-4 text-dark shadow-sm" @onclick="GuardarCambiosCliente">Guardar Cambios</button>
                </div>
            </div>
        </div>
    </div>
}

@* MODAL DE ASIGNACION (VALIDADO) *@
@if (mostrarModalAsignacion)
{
    <div class="modal fade show d-block fade-in" tabindex="-1" style="background-color: rgba(4, 5, 8, 0.8); backdrop-filter: blur(8px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border border-secondary border-opacity-25 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-header border-bottom border-secondary border-opacity-25 p-4">
                    <h5 class="modal-title fw-black text-white d-flex align-items-center">
                        <div class="bg-gradient-primary rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="bi bi-person-badge text-dark fs-5"></i>
                        </div>
                        Asignar Entrenador
                    </h5>
                    <button type="button" class="btn-close btn-close-white opacity-50 shadow-none" @onclick="CerrarModalAsignacion"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-4 text-muted">Panel de asignación para <strong class="text-white">@clienteAsignacion.Nombre @clienteAsignacion.Apellido</strong></p>
                    
                    @if (yaTieneEntrenador)
                    {
                        @* ALERTA SI YA TIENE ENTRENADOR *@
                        <div class="alert alert-warning bg-warning bg-opacity-10 border-warning border-opacity-25 text-warning mb-4 rounded-3 d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                            <div>
                                <div class="fw-bold tracking-wide">Asignación Bloqueada</div>
                                <small>Este atleta ya está bajo la supervisión de un coach. No se puede reasignar desde aquí.</small>
                            </div>
                        </div>

                        <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Coach Actual</label>
                        <select class="form-select bg-dark border-secondary border-opacity-25 text-white-50 shadow-none rounded-3 py-2" disabled>
                            <option selected>@(nombresEntrenadores.GetValueOrDefault(idEntrenadorSeleccionado, "Entrenador Asignado"))</option>
                        </select>
                    }
                    else
                    {
                        @* FORMULARIO NORMAL SI ESTÁ LIBRE *@
                        <label class="form-label fw-bold text-muted small text-uppercase tracking-widest">Coach Disponible</label>
                        <select class="form-select bg-transparent border-secondary border-opacity-50 text-white shadow-none rounded-3 py-2" @bind="idEntrenadorSeleccionado">
                            <option value="0" disabled selected class="text-dark">-- Elige un entrenador --</option>
                            @if (listaEntrenadores != null)
                            {
                                @foreach (var coach in listaEntrenadores)
                                {
                                    <option value="@coach.Id" class="text-dark">@coach.NombreCompleto</option>
                                }
                            }
                        </select>
                    }
                </div>
                <div class="modal-footer border-top border-secondary border-opacity-25 p-4" style="background-color: rgba(255,255,255,0.02);">
                    <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold px-4" @onclick="CerrarModalAsignacion">Cancelar</button>
                    
                    @* OCULTAMOS EL BOTON DE CONFIRMAR SI YA TIENE COACH *@
                    @if (!yaTieneEntrenador)
                    {
                        <button type="button" class="btn btn-gradient fw-bold rounded-pill px-4 shadow-sm" @onclick="GuardarAsignacion">Confirmar</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* variables y base */
    .page-container { font-family: 'Segoe UI', Roboto, sans-serif; }
    .bg-gradient-primary { background: linear-gradient(135deg, #00FFA3, #00B8D4); }
    .bg-gradient-info { background: linear-gradient(135deg, #00B8D4, #0077ff); }
    .text-primary { color: #00FFA3 !important; }
    
    .btn-gradient { background: linear-gradient(135deg, #00FFA3, #00B8D4); color: #040508; border: none; }
    .btn-gradient:hover { background: linear-gradient(135deg, #00e693, #00a5bf); color: #040508; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0, 255, 163, 0.3) !important; }

    /* separacion de filas estilo tarjetas */
    .modern-table { border-collapse: separate; border-spacing: 0; }
    .modern-row td { background-color: #0f141e; border-top: 1px solid rgba(255, 255, 255, 0.02); border-bottom: 1px solid rgba(255, 255, 255, 0.02); transition: all 0.2s ease; }
    .modern-row td:first-child { border-left: 1px solid rgba(255, 255, 255, 0.02); }
    .modern-row td:last-child { border-right: 1px solid rgba(255, 255, 255, 0.02); }
    .row-spacer td { height: 10px; padding: 0; background: transparent; border: none; }
    .modern-row:hover td { background-color: #161d2b; transform: scale(1.005); }

    /* inputs y selects modernos */
    .form-control:focus, .form-select:focus { background-color: rgba(255,255,255,0.05) !important; border-color: #00FFA3 !important; color: white !important; box-shadow: 0 0 0 0.25rem rgba(0, 255, 163, 0.25) !important; }
    .form-switch .form-check-input:checked { background-color: #00FFA3; border-color: #00FFA3; }

    /* botones de accion pequeños */
    .btn-outline-info { color: #00B8D4; border-color: rgba(0, 184, 212, 0.5); }
    .btn-outline-info:hover { background-color: #00B8D4; color: #040508; border-color: #00B8D4; }
    .btn-outline-success { color: #00FFA3; border-color: rgba(0, 255, 163, 0.5); }
    .btn-outline-success:hover { background-color: #00FFA3; color: #040508; border-color: #00FFA3; }
    .upload-zone { background-color: rgba(255,255,255,0.03); border: 1px dashed rgba(0, 255, 163, 0.28); transition: border-color .2s ease, background-color .2s ease; }
    .upload-zone.drag-over { background-color: rgba(0, 255, 163, 0.08); border-color: #00FFA3; }
    .profile-preview { width: 64px; height: 64px; flex: 0 0 64px; border-radius: 50%; background: linear-gradient(135deg, rgba(0,255,163,0.16), rgba(0,184,212,0.1)); border: 1px solid rgba(0,255,163,0.28); display: flex; align-items: center; justify-content: center; overflow: hidden; color: #00FFA3; font-size: 1.8rem; }
    .profile-preview img { width: 100%; height: 100%; object-fit: cover; display: block; }

    /* utilidades */
    .tracking-widest { letter-spacing: 0.1em; }
    .tracking-wide { letter-spacing: 0.05em; }
    .transition-hover { transition: all 0.3s ease; }
    .fade-in { animation: fadeIn 0.3s ease-in-out; }
    .slide-up { animation: slideUp 0.3s ease-out; }
    
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

    .custom-scrollbar::-webkit-scrollbar { height: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0, 255, 163, 0.2); border-radius: 10px; }
</style>

@code {
    private List<Cliente>? listaClientes;
    private string terminoBusqueda = "";

    // Caché para mostrar en la tabla
    private Dictionary<int, string> nombresEntrenadores = new();
    private Dictionary<int, int> asignacionesClientes = new();

    // variables para el modal de edicion
    private bool mostrarModal = false;
    private Cliente clienteActual = new Cliente();
    private IBrowserFile? fotoClienteEdicion;
    private string? fotoClientePreviewUrl;
    private string? nombreFotoClienteEdicion;
    private string mensajeErrorModal = "";

    // variables para el modal de asignacion
    private bool mostrarModalAsignacion = false;
    private Cliente clienteAsignacion = new Cliente();
    private List<Usuario> listaEntrenadores = new List<Usuario>();
    private int idEntrenadorSeleccionado = 0;
    private bool yaTieneEntrenador = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (mostrarModal)
        {
            await JS.InvokeVoidAsync("gymioFileUpload.bindDropZone", "foto-cliente-edicion-drop", "foto-cliente-edicion-input");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        
        listaEntrenadores = await ClienteService.ObtenerEntrenadoresAsync();
        if (listaEntrenadores != null)
        {
            foreach (var coach in listaEntrenadores)
            {
                nombresEntrenadores[coach.Id] = coach.NombreCompleto;
            }
        }

        await CargarClientes();
    }

    private async Task RealizarBusqueda()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        listaClientes = await ClienteService.ObtenerClientesAsync(terminoBusqueda);

       
        asignacionesClientes.Clear();
        if (listaClientes != null)
        {
            foreach (var cliente in listaClientes)
            {
                int coachId = await ClienteService.ObtenerIdEntrenadorAsignadoAsync(cliente.Id);
                
              
                if (coachId > 0) 
                {
                    asignacionesClientes[cliente.Id] = coachId;
                }
            }
        }
    }

    private void AbrirModalEdicion(Cliente cliente)
    {
        clienteActual = new Cliente
        {
            Id = cliente.Id,
            Nombre = cliente.Nombre,
            Apellido = cliente.Apellido,
            Email = cliente.Email,
            Telefono = cliente.Telefono,
            CodigoQR = cliente.CodigoQR,
            FechaRegistro = cliente.FechaRegistro,
            Activo = cliente.Activo,
            FotoUrl = cliente.FotoUrl,
            PasswordHash = cliente.PasswordHash
        };
        fotoClienteEdicion = null;
        fotoClientePreviewUrl = null;
        nombreFotoClienteEdicion = null;
        mensajeErrorModal = "";
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        fotoClienteEdicion = null;
        fotoClientePreviewUrl = null;
        nombreFotoClienteEdicion = null;
        mensajeErrorModal = "";
    }

    private async Task GuardarCambiosCliente()
    {
        mensajeErrorModal = "";

        try
        {
            if (fotoClienteEdicion != null)
            {
                clienteActual.FotoUrl = await ProfileImageService.GuardarImagenPerfilAsync(fotoClienteEdicion, "clientes", clienteActual.FotoUrl);
            }
        }
        catch (Exception ex)
        {
            mensajeErrorModal = ex.Message;
            return;
        }

        await ClienteService.ActualizarClienteAsync(clienteActual);
        await CargarClientes();
        CerrarModal();
    }

    private async Task SeleccionarFotoClienteEdicion(InputFileChangeEventArgs e)
    {
        mensajeErrorModal = "";
        fotoClienteEdicion = e.File;
        nombreFotoClienteEdicion = fotoClienteEdicion.Name;

        try
        {
            fotoClientePreviewUrl = await ProfileImageService.CrearVistaPreviaAsync(fotoClienteEdicion);
        }
        catch (Exception ex)
        {
            fotoClienteEdicion = null;
            nombreFotoClienteEdicion = null;
            fotoClientePreviewUrl = null;
            mensajeErrorModal = ex.Message;
        }
    }

    private async Task AbrirModalAsignacion(Cliente cliente)
    {
        clienteAsignacion = cliente;
        
        
        idEntrenadorSeleccionado = await ClienteService.ObtenerIdEntrenadorAsignadoAsync(cliente.Id);
        
        
        yaTieneEntrenador = idEntrenadorSeleccionado > 0;

        mostrarModalAsignacion = true;
    }

    private void CerrarModalAsignacion()
    {
        mostrarModalAsignacion = false;
    }

    private async Task GuardarAsignacion()
    {
        
        if (idEntrenadorSeleccionado > 0 && !yaTieneEntrenador)
        {
            await ClienteService.AsignarEntrenadorAsync(clienteAsignacion.Id, idEntrenadorSeleccionado);
            await CargarClientes(); 
            mostrarModalAsignacion = false;
        }
    }
}
