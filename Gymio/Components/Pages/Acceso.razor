@page "/acceso"
@rendermode InteractiveServer

@using Gymio.Models
@using Gymio.Interfaces
@inject IClienteService ClienteService

@inject IJSRuntime JS

<div class="container-fluid min-vh-100 d-flex flex-column align-items-center justify-content-center bg-body-tertiary py-5">
    
    <div class="text-center mb-4">
        <h1 class="fw-black text-body" style="letter-spacing: -1px; font-size: 2.5rem;">Control de Acceso</h1>
        <p class="text-secondary fw-medium">Escanee la tarjeta o código del socio</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4" style="max-width: 550px; width: 100%;">
        <div class="card-body p-4 p-md-5 text-center">
            
            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex p-3 mb-4">
                <span class="fs-1">📟</span>
            </div>

            <input type="text"
                   @ref="inputScanner"
                   class="form-control form-control-lg text-center fw-bold fs-3 border-2 border-primary border-opacity-50 shadow-none py-3"
                   style="letter-spacing: 3px;"
                   placeholder="ESPERANDO LECTURA..."
                   @bind="codigoEscaneado"
                   @bind:event="oninput"
                   @onkeydown="ProcesarEscaneo"
                   autocomplete="off" />
                   
            <small class="text-muted mt-3 d-block fw-bold opacity-75">El escáner procesará automáticamente.</small>
        </div>
    </div>

    <div style="height: 250px; max-width: 550px; width: 100%;">
        @if (busquedaRealizada)
        {
            if (clienteEncontrado != null)
            {
                if (clienteEncontrado.Activo)
                {
                    <div class="card border-0 bg-success bg-opacity-10 h-100 rounded-4 shadow-sm">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                            <span class="fs-1 mb-2">✅</span>
                            <h2 class="fw-bold text-success mb-1">ACCESO PERMITIDO</h2>
                            <h4 class="fw-bold text-body">@clienteEncontrado.Nombre @clienteEncontrado.Apellido</h4>
                            <span class="badge bg-success mt-2 px-3 py-2">MEMBRESÍA ACTIVA</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card border-0 bg-danger bg-opacity-10 h-100 rounded-4 shadow-sm">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                            <span class="fs-1 mb-2">⛔</span>
                            <h2 class="fw-bold text-danger mb-1">ACCESO DENEGADO</h2>
                            <h4 class="fw-bold text-body">@clienteEncontrado.Nombre @clienteEncontrado.Apellido</h4>
                            <span class="badge bg-danger mt-2 px-3 py-2">MEMBRESÍA INACTIVA O VENCIDA</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="card border-0 bg-warning bg-opacity-10 h-100 rounded-4 shadow-sm">
                    <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                        <span class="fs-1 mb-2">⚠️</span>
                        <h3 class="fw-bold text-warning mb-1">CÓDIGO DESCONOCIDO</h3>
                        <p class="text-body fw-medium mb-0">El QR [@codigoRebotado] no pertenece a ningún socio.</p>
                    </div>
                </div>
            }
        }
    </div>

</div>

@code {
    private ElementReference inputScanner;
    private string codigoEscaneado = "";
    private string codigoRebotado = "";
    private bool busquedaRealizada = false;
    private Cliente? clienteEncontrado;

    // Fuerza a que el cursor siempre esté en el cuadro de texto al cargar la página
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await inputScanner.FocusAsync();
        }
    }

    private async Task ProcesarEscaneo(KeyboardEventArgs e)
    {
        // El escáner envía la tecla "Enter" cuando termina de leer el código
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(codigoEscaneado))
        {
            codigoRebotado = codigoEscaneado.Trim(); // Guardamos el código por si falla
            
            // 1. Buscamos en SQL Server
            clienteEncontrado = await ClienteService.ObtenerClientePorQRAsync(codigoRebotado);
            busquedaRealizada = true;

            // 2. Si existe, guardamos en el historial de Asistencias (pase o no pase)
            if (clienteEncontrado != null)
            {
                await ClienteService.RegistrarAsistenciaAsync(clienteEncontrado.Id, clienteEncontrado.Activo);
            }

            // 3. Limpiamos el cuadro instantáneamente para la siguiente persona
            codigoEscaneado = "";
            
            // Forzamos la actualización de la pantalla
            StateHasChanged();
            
            // Volvemos a poner el cursor en la caja por si el usuario hizo clic en otro lado
            await inputScanner.FocusAsync();
        }
    }
}